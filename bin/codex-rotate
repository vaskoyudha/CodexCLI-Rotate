#!/usr/bin/env bash
set -euo pipefail

# codex-rotate
# Account rotation manager for Codex CLI auth profiles.
#
# Design summary:
# - Stores per-account credentials under ~/.codex-accounts/credentials/<alias>.json
# - Maintains metadata in ~/.codex-accounts/state.json
# - Uses atomic symlink swap for ~/.codex/auth.json (or $CODEX_HOME/auth.json)
# - Supports round-robin switching, cooldowns, and automatic retries on rate limit

###############################################################################
# Global constants and derived paths
###############################################################################

SCRIPT_NAME="codex-rotate"
SCRIPT_VERSION="1.2.0"

HOME_DIR="${HOME:?HOME environment variable must be set}"
ACCOUNTS_DIR="${HOME_DIR}/.codex-accounts"
CONFIG_FILE="${ACCOUNTS_DIR}/config.sh"
STATE_FILE="${ACCOUNTS_DIR}/state.json"
ORDER_FILE="${ACCOUNTS_DIR}/order"
ACTIVE_FILE="${ACCOUNTS_DIR}/active"
CREDENTIALS_DIR="${ACCOUNTS_DIR}/credentials"
LOCK_DIR="${ACCOUNTS_DIR}/locks"
LOCK_FILE="${LOCK_DIR}/state.lock"

# Honor CODEX_HOME if explicitly set by user.
if [[ -n "${CODEX_HOME:-}" ]]; then
  CODEX_DIR="${CODEX_HOME}"
  WARN_CODEX_HOME=1
else
  CODEX_DIR="${HOME_DIR}/.codex"
  WARN_CODEX_HOME=0
fi

CODEX_AUTH="${CODEX_DIR}/auth.json"
CODEX_AUTH_BACKUP="${CODEX_DIR}/auth.json.backup"

DEFAULT_CODEX_BIN=""

# Default config values (overridden by ~/.codex-accounts/config.sh)
ROTATION_INTERVAL=10800
HOURLY_COOLDOWN=3600
DAILY_COOLDOWN=86400
WEEKLY_COOLDOWN=604800
MAX_RETRIES=3
CODEX_BIN=""
QUOTA_AWARE_ROTATION=0
NOTIFY_DESKTOP=0
NOTIFY_WEBHOOK_URL=""
NOTIFY_WEBHOOK_TYPE=""

###############################################################################
# ANSI colors and output helpers
###############################################################################

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
WHITE="\033[37m"
RESET="\033[0m"

log_info() {
  printf "%b[INFO]%b %s\n" "${BLUE}" "${RESET}" "$*"
}

log_warn() {
  printf "%b[WARN]%b %s\n" "${YELLOW}" "${RESET}" "$*" >&2
}

log_error() {
  printf "%b[ERROR]%b %s\n" "${RED}" "${RESET}" "$*" >&2
}

log_success() {
  printf "%b[OK]%b %s\n" "${GREEN}" "${RESET}" "$*"
}

die() {
  log_error "$*"
  exit 1
}

###############################################################################
# Validation and dependency checks
###############################################################################

check_prerequisites() {
  command -v jq >/dev/null 2>&1 || die "jq is required but not installed"
  command -v flock >/dev/null 2>&1 || die "flock is required but not installed"
  command -v mktemp >/dev/null 2>&1 || die "mktemp is required but not installed"
  command -v date >/dev/null 2>&1 || die "date is required but not installed"
  command -v stat >/dev/null 2>&1 || die "stat is required but not installed"
  command -v curl >/dev/null 2>&1 || log_warn "curl not found — quota/refresh features will be unavailable"

  if (( WARN_CODEX_HOME == 1 )); then
    log_warn "CODEX_HOME is set to '${CODEX_HOME}'. Using that location for auth.json/config.toml."
  fi
}

resolve_codex_bin() {
  if [[ -n "${CODEX_BIN}" ]]; then
    command -v "${CODEX_BIN}" >/dev/null 2>&1 || die "Configured CODEX_BIN not executable: ${CODEX_BIN}"
    return
  fi

  if command -v codex >/dev/null 2>&1; then
    CODEX_BIN="$(command -v codex)"
    return
  fi

  if [[ -x "${DEFAULT_CODEX_BIN}" ]]; then
    CODEX_BIN="${DEFAULT_CODEX_BIN}"
    return
  fi

  die "Could not find codex binary. Set CODEX_BIN in ${CONFIG_FILE}."
}

validate_alias() {
  local alias="$1"
  [[ -n "${alias}" ]] || return 1
  [[ "${alias}" =~ ^[a-zA-Z0-9_-]+$ ]] || return 1
  [[ "${alias}" != *"/"* ]] || return 1
  [[ "${alias}" != *".."* ]] || return 1
  return 0
}

require_initialized() {
  [[ -d "${ACCOUNTS_DIR}" ]] || die "Not initialized. Run: ${SCRIPT_NAME} init"
  [[ -f "${CONFIG_FILE}" ]] || die "Missing config file: ${CONFIG_FILE}. Run: ${SCRIPT_NAME} init"
  [[ -f "${STATE_FILE}" ]] || die "Missing state file: ${STATE_FILE}. Run: ${SCRIPT_NAME} init"
  [[ -f "${ORDER_FILE}" ]] || die "Missing order file: ${ORDER_FILE}. Run: ${SCRIPT_NAME} init"
  [[ -f "${ACTIVE_FILE}" ]] || die "Missing active file: ${ACTIVE_FILE}. Run: ${SCRIPT_NAME} init"
  [[ -d "${CREDENTIALS_DIR}" ]] || die "Missing credentials dir: ${CREDENTIALS_DIR}. Run: ${SCRIPT_NAME} init"
  mkdir -p "${LOCK_DIR}"
  touch "${LOCK_FILE}"
}

###############################################################################
# Locking
###############################################################################

with_lock() { flock -x "${LOCK_FILE}" -c "$1"; }

send_notification() {
  local title="$1"
  local message="$2"

  # Desktop notification
  if [[ "${NOTIFY_DESKTOP}" -eq 1 ]]; then
    if command -v notify-send >/dev/null 2>&1; then
      notify-send "${title}" "${message}" 2>/dev/null || true
    elif command -v osascript >/dev/null 2>&1; then
      osascript -e "display notification \"${message}\" with title \"${title}\"" 2>/dev/null || true
    fi
  fi

  # Webhook notification
  if [[ -n "${NOTIFY_WEBHOOK_URL}" ]]; then
    local payload=""
    case "${NOTIFY_WEBHOOK_TYPE}" in
      slack)
        payload="$(jq -nc --arg text "${title}: ${message}" '{"text": $text}')"
        ;;
      discord)
        payload="$(jq -nc --arg content "${title}: ${message}" '{"content": $content}')"
        ;;
      telegram)
        payload="$(jq -nc --arg text "${title}\n${message}" '{"text": $text}')"
        ;;
      *)
        payload="$(jq -nc --arg title "${title}" --arg message "${message}" '{"title": $title, "message": $message}')"
        ;;
    esac
    curl -fsSL -X POST -H "Content-Type: application/json" -d "${payload}" "${NOTIFY_WEBHOOK_URL}" >/dev/null 2>&1 || true
  fi
}

###############################################################################
# Time helpers
###############################################################################

now_epoch() {
  date +%s
}

now_iso() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

iso_to_epoch() {
  local ts="$1"
  if [[ -z "${ts}" ]]; then
    printf "0"
    return 0
  fi
  if ! date -u -d "${ts}" +%s >/dev/null 2>&1; then
    printf "0"
    return 0
  fi
  date -u -d "${ts}" +%s
}

format_duration() {
  local total="${1:-0}"
  if [[ -z "${total}" || "${total}" -le 0 ]]; then
    printf "0s"
    return 0
  fi

  local days hours mins secs
  days=$(( total / 86400 ))
  hours=$(( (total % 86400) / 3600 ))
  mins=$(( (total % 3600) / 60 ))
  secs=$(( total % 60 ))

  if (( days > 0 )); then
    if (( hours > 0 )); then
      printf "%dd %dh" "${days}" "${hours}"
    else
      printf "%dd" "${days}"
    fi
    return 0
  fi

  if (( hours > 0 )); then
    if (( mins > 0 )); then
      printf "%dh %dm" "${hours}" "${mins}"
    else
      printf "%dh" "${hours}"
    fi
    return 0
  fi

  if (( mins > 0 )); then
    printf "%dm" "${mins}"
    return 0
  fi

  printf "%ds" "${secs}"
}

format_time_ago() {
  local epoch="${1:-0}"
  if [[ -z "${epoch}" || "${epoch}" -le 0 ]]; then
    printf "never"
    return 0
  fi

  local now diff
  now="$(now_epoch)"
  diff=$(( now - epoch ))
  if (( diff < 0 )); then
    printf "just now"
    return 0
  fi

  if (( diff < 60 )); then
    printf "%ss ago" "${diff}"
    return 0
  fi
  if (( diff < 3600 )); then
    printf "%sm ago" "$(( diff / 60 ))"
    return 0
  fi
  if (( diff < 86400 )); then
    printf "%sh ago" "$(( diff / 3600 ))"
    return 0
  fi
  printf "%sd ago" "$(( diff / 86400 ))"
}

###############################################################################
# Config loading
###############################################################################

load_config() {
  if [[ -f "${CONFIG_FILE}" ]]; then
    # shellcheck disable=SC1090
    source "${CONFIG_FILE}"
  fi
  # Allow environment variable to override config for subprocess propagation.
  # cmd_auto exports CODEX_ROTATE__QUOTA_AWARE=1 which must survive the
  # with_lock subprocess boundary (flock spawns a new process that re-enters
  # main→load_config, resetting QUOTA_AWARE_ROTATION from config.sh).
  if [[ "${CODEX_ROTATE__QUOTA_AWARE:-}" == "1" ]]; then
    QUOTA_AWARE_ROTATION=1
  fi
  resolve_codex_bin
}

write_default_config() {
  local tmp
  tmp="$(mktemp "${CONFIG_FILE}.tmp.XXXXXX")"
  cat > "${tmp}" <<'EOF'
# codex-rotate configuration
# Edit and re-run to apply changes

ROTATION_INTERVAL=10800        # Time-based rotation interval (seconds) — 3 hours
HOURLY_COOLDOWN=3600           # Cooldown for hourly rate limit (1 hour)
DAILY_COOLDOWN=86400           # Cooldown for daily rate limit (24 hours)
WEEKLY_COOLDOWN=604800         # Cooldown for weekly rate limit (7 days)
MAX_RETRIES=3                  # Max retries after rate limit before giving up
CODEX_BIN=""                   # Override codex binary path (auto-detected if empty)
QUOTA_AWARE_ROTATION=0         # Set to 1 to prefer lowest-usage account in 'auto' mode
NOTIFY_DESKTOP=0               # Set to 1 to enable desktop notifications
NOTIFY_WEBHOOK_URL=""          # Webhook URL (Slack, Discord, etc.)
NOTIFY_WEBHOOK_TYPE=""         # Type: slack, discord, telegram, generic
EOF
  mv -f "${tmp}" "${CONFIG_FILE}"
}

###############################################################################
# State management (jq + atomic writes)
###############################################################################

read_state() {
  [[ -f "${STATE_FILE}" ]] || die "Missing state file: ${STATE_FILE}"
  jq '.' "${STATE_FILE}"
}

write_state() {
  local filter="$1"
  shift
  local tmp
  tmp="$(mktemp "${STATE_FILE}.tmp.XXXXXX")"

  if ! jq "$@" "${filter}" "${STATE_FILE}" > "${tmp}"; then
    rm -f "${tmp}"
    die "Failed updating state with jq filter: ${filter}"
  fi

  mv -f "${tmp}" "${STATE_FILE}"
}

get_account_state() {
  local alias="$1"
  local field="$2"
  jq -r --arg alias "${alias}" --arg field "${field}" '.accounts[$alias][$field] // empty' "${STATE_FILE}"
}

set_account_state() {
  local alias="$1"
  local field="$2"
  local value="$3"

  if [[ "${value}" =~ ^-?[0-9]+$ ]]; then
    # shellcheck disable=SC2016
    write_state '.accounts[$alias][$field] = $value' \
      --arg alias "${alias}" \
      --arg field "${field}" \
      --argjson value "${value}"
  else
    # shellcheck disable=SC2016
    write_state '.accounts[$alias][$field] = $value' \
      --arg alias "${alias}" \
      --arg field "${field}" \
      --arg value "${value}"
  fi
}

init_account_state_entry() {
  local alias="$1"
  local group="${2:-}"
  # shellcheck disable=SC2016
  write_state '.accounts[$alias] = {
      "cooldown_until": 0,
      "total_uses": 0,
      "last_used": "",
      "rate_limit_hits": 0,
      "last_rate_limit": "",
      "group": $group
    }' --arg alias "${alias}" --arg group "${group}"
}

delete_account_state_entry() {
  local alias="$1"
  # shellcheck disable=SC2016
  write_state 'del(.accounts[$alias])' --arg alias "${alias}"
}

get_account_group() {
  local alias="$1"
  jq -r --arg a "${alias}" '.accounts[$a].group // ""' "${STATE_FILE}" 2>/dev/null || echo ""
}

set_account_group() {
  local alias="$1"
  local group="$2"
  local tmp="${STATE_FILE}.tmp.$$"
  jq --arg a "${alias}" --arg g "${group}" '.accounts[$a].group = $g' "${STATE_FILE}" > "${tmp}" && mv "${tmp}" "${STATE_FILE}"
}

###############################################################################
# Account/order helpers
###############################################################################

get_active() {
  [[ -f "${ACTIVE_FILE}" ]] || {
    printf ""
    return 0
  }
  local active
  IFS= read -r active < "${ACTIVE_FILE}" || true
  printf "%s" "${active:-}"
}

set_active() {
  local alias="$1"
  local tmp
  tmp="$(mktemp "${ACTIVE_FILE}.tmp.XXXXXX")"
  printf "%s\n" "${alias}" > "${tmp}"
  mv -f "${tmp}" "${ACTIVE_FILE}"
}

get_order() {
  [[ -f "${ORDER_FILE}" ]] || return 0
  local line
  while IFS= read -r line || [[ -n "${line}" ]]; do
    [[ -z "${line}" ]] && continue
    printf "%s\n" "${line}"
  done < "${ORDER_FILE}"
}

append_order() {
  local alias="$1"
  local exists=0
  local line
  while IFS= read -r line || [[ -n "${line}" ]]; do
    if [[ "${line}" == "${alias}" ]]; then
      exists=1
      break
    fi
  done < "${ORDER_FILE}"

  if (( exists == 0 )); then
    printf "%s\n" "${alias}" >> "${ORDER_FILE}"
  fi
}

remove_from_order() {
  local alias="$1"
  local tmp
  tmp="$(mktemp "${ORDER_FILE}.tmp.XXXXXX")"
  local line
  while IFS= read -r line || [[ -n "${line}" ]]; do
    [[ -z "${line}" ]] && continue
    [[ "${line}" == "${alias}" ]] && continue
    printf "%s\n" "${line}" >> "${tmp}"
  done < "${ORDER_FILE}"
  mv -f "${tmp}" "${ORDER_FILE}"
}

account_exists() {
  local alias="$1"
  [[ -f "${CREDENTIALS_DIR}/${alias}.json" ]]
}

is_on_cooldown() {
  local alias="$1"
  local now cooldown_until
  now="$(now_epoch)"
  cooldown_until="$(get_account_state "${alias}" "cooldown_until")"
  cooldown_until="${cooldown_until:-0}"
  [[ "${cooldown_until}" =~ ^[0-9]+$ ]] || cooldown_until=0
  (( cooldown_until > now ))
}

cooldown_remaining() {
  local alias="$1"
  local now cooldown_until
  now="$(now_epoch)"
  cooldown_until="$(get_account_state "${alias}" "cooldown_until")"
  cooldown_until="${cooldown_until:-0}"
  [[ "${cooldown_until}" =~ ^[0-9]+$ ]] || cooldown_until=0

  if (( cooldown_until > now )); then
    printf "%s" "$(( cooldown_until - now ))"
  else
    printf "0"
  fi
}

clear_expired_cooldown_if_needed() {
  local alias="$1"
  local cooldown_until now
  cooldown_until="$(get_account_state "${alias}" "cooldown_until")"
  cooldown_until="${cooldown_until:-0}"
  [[ "${cooldown_until}" =~ ^[0-9]+$ ]] || cooldown_until=0
  now="$(now_epoch)"

  if (( cooldown_until > 0 && cooldown_until <= now )); then
    set_account_state "${alias}" "cooldown_until" "0"
    send_notification "codex-rotate" "Account '${alias}' cooldown expired — now available"
  fi
}

get_next_available() {
  local target_group="${CODEX_ROTATE__GROUP:-}"

  # If quota-aware rotation is enabled, try quota-based selection first
  if (( QUOTA_AWARE_ROTATION == 1 )); then
    local quota_pick
    quota_pick="$(get_best_quota_account)"
    if [[ -n "${quota_pick}" ]]; then
      printf "%s" "${quota_pick}"
      return 0
    fi
  fi

  # Fallback: round-robin
  mapfile -t all_aliases < <(get_order)
  local total="${#all_aliases[@]}"
  (( total > 0 )) || {
    printf ""
    return 0
  }

  local active start_idx i idx alias
  active="$(get_active)"
  start_idx=0

  if [[ -n "${active}" ]]; then
    for i in "${!all_aliases[@]}"; do
      if [[ "${all_aliases[$i]}" == "${active}" ]]; then
        start_idx=$(( (i + 1) % total ))
        break
      fi
    done
  fi

  for (( i=0; i<total; i++ )); do
    idx=$(( (start_idx + i) % total ))
    alias="${all_aliases[$idx]}"
    [[ -f "${CREDENTIALS_DIR}/${alias}.json" ]] || continue
    clear_expired_cooldown_if_needed "${alias}"
    if [[ -n "${target_group}" ]] && [[ "$(get_account_group "${alias}")" != "${target_group}" ]]; then
      continue
    fi
    if ! is_on_cooldown "${alias}"; then
      printf "%s" "${alias}"
      return 0
    fi
  done

  printf ""
}

get_next_with_fallback() {
  # Best effort helper: returns next available; if all cooldown, returns next with creds.
  local next
  next="$(get_next_available)"
  if [[ -n "${next}" ]]; then
    printf "%s" "${next}"
    return 0
  fi

  mapfile -t all_aliases < <(get_order)
  local alias
  for alias in "${all_aliases[@]}"; do
    [[ -f "${CREDENTIALS_DIR}/${alias}.json" ]] || continue
    printf "%s" "${alias}"
    return 0
  done
  printf ""
}

get_best_quota_account() {
  # Attempt to find the account with the lowest primary window usage.
  # Falls back to round-robin if quota data is unavailable.
  command -v curl >/dev/null 2>&1 || {
    printf ""
    return 0
  }

  mapfile -t all_aliases < <(get_order)
  local total="${#all_aliases[@]}"
  (( total > 0 )) || { printf ""; return 0; }

  local best_alias="" best_pct=101
  local alias tokens usage_json pct
  local target_group="${CODEX_ROTATE__GROUP:-}"

  for alias in "${all_aliases[@]}"; do
    [[ -f "${CREDENTIALS_DIR}/${alias}.json" ]] || continue
    clear_expired_cooldown_if_needed "${alias}"
    if [[ -n "${target_group}" ]] && [[ "$(get_account_group "${alias}")" != "${target_group}" ]]; then
      continue
    fi
    is_on_cooldown "${alias}" && continue

    tokens="$(get_account_tokens "${alias}")"
    # Skip API key accounts (no usage API)
    if [[ "$(printf "%s" "${tokens}" | jq -r '.mode // empty')" == "api_key" ]]; then
      if [[ -z "${best_alias}" ]]; then
        best_alias="${alias}"
      fi
      continue
    fi

    usage_json="$(query_usage_api "${alias}" 2>/dev/null)"
    if [[ -z "${usage_json}" || "${usage_json}" == ERROR:* ]]; then
      if [[ -z "${best_alias}" ]]; then
        best_alias="${alias}"
      fi
      continue
    fi

    pct="$(parse_usage_percent "${usage_json}")"
    pct="${pct%%.*}"
    [[ "${pct}" =~ ^[0-9]+$ ]] || pct=0

    # Skip accounts at 90%+ usage
    if (( pct >= 90 )); then
      continue
    fi

    if (( pct < best_pct )); then
      best_pct="${pct}"
      best_alias="${alias}"
    fi
  done

  printf "%s" "${best_alias}"
}

###############################################################################
# Symlink management
###############################################################################

backup_original_auth_if_needed() {
  mkdir -p "${CODEX_DIR}"
  if [[ -L "${CODEX_AUTH}" ]]; then
    return 0
  fi
  if [[ -f "${CODEX_AUTH}" && ! -f "${CODEX_AUTH_BACKUP}" ]]; then
    cp -a "${CODEX_AUTH}" "${CODEX_AUTH_BACKUP}"
    log_info "Backed up original auth.json to ${CODEX_AUTH_BACKUP}"
  fi
}

ensure_symlink() {
  local alias="$1"
  local target="${CREDENTIALS_DIR}/${alias}.json"
  [[ -r "${target}" ]] || die "Credential target not readable: ${target}"

  mkdir -p "${CODEX_DIR}"
  local tmp_link
  tmp_link="${CODEX_AUTH}.tmp.$$"

  ln -sf "${target}" "${tmp_link}"
  mv -f "${tmp_link}" "${CODEX_AUTH}"
}

validate_symlink() {
  [[ -L "${CODEX_AUTH}" ]] || return 1
  local target
  target="$(readlink "${CODEX_AUTH}" || true)"
  [[ -n "${target}" ]] || return 1
  [[ -r "${target}" ]]
}

###############################################################################
# Rate-limit detection and cooldown classification
###############################################################################

rate_limit_regex() {
  printf '%s' 'usageLimitExceeded|responseTooManyFailedAttempts|429|rate[[:space:]-]*limit|too[[:space:]]+many[[:space:]]+requests|usage[[:space:]]+cap|account/rateLimits/updated|you'
  printf "'"
  printf '%s' 've[[:space:]]+reached|capacity|try[[:space:]]+again[[:space:]]+later|limit[[:space:]]+exceeded'
}

detect_rate_limit() {
  local file="$1"
  [[ -f "${file}" ]] || return 1
  local regex
  regex="$(rate_limit_regex)"
  jq -Rsr --arg re "${regex}" 'test($re; "i")' "${file}" | jq -e '. == true' >/dev/null 2>&1
}

classify_cooldown() {
  local file="$1"
  [[ -f "${file}" ]] || {
    printf "%s" "${HOURLY_COOLDOWN}"
    return 0
  }

  local text
  text="$(jq -Rsr '.' "${file}" | tr '[:upper:]' '[:lower:]')"

  # Heuristics: prefer strongest/longest phrases first.
  if [[ "${text}" == *"weekly"* || "${text}" == *"7 day"* || "${text}" == *"7-day"* || "${text}" == *"week"* ]]; then
    printf "%s" "${WEEKLY_COOLDOWN}"
    return 0
  fi

  if [[ "${text}" == *"daily"* || "${text}" == *"24 hour"* || "${text}" == *"24-hour"* || "${text}" == *"day"* || "${text}" == *"tomorrow"* ]]; then
    printf "%s" "${DAILY_COOLDOWN}"
    return 0
  fi

  if [[ "${text}" == *"hour"* || "${text}" == *"60 minute"* || "${text}" == *"1h"* ]]; then
    printf "%s" "${HOURLY_COOLDOWN}"
    return 0
  fi

  # If numeric hour appears (e.g., "try again in 2 hours")
  local guessed_hours
  guessed_hours="$(jq -Rsr 'capture("(?<n>[0-9]+)\\s*hours?")?.n // empty' "${file}" 2>/dev/null || true)"
  if [[ -n "${guessed_hours}" && "${guessed_hours}" =~ ^[0-9]+$ ]]; then
    printf "%s" "$(( guessed_hours * 3600 ))"
    return 0
  fi

  printf "%s" "${HOURLY_COOLDOWN}"
}

mark_rate_limit_hit() {
  local alias="$1"
  local cooldown_secs="$2"
  local until now_iso_ts current_hits
  until=$(( $(now_epoch) + cooldown_secs ))
  now_iso_ts="$(now_iso)"
  current_hits="$(get_account_state "${alias}" "rate_limit_hits")"
  current_hits="${current_hits:-0}"
  [[ "${current_hits}" =~ ^[0-9]+$ ]] || current_hits=0

  set_account_state "${alias}" "cooldown_until" "${until}"
  set_account_state "${alias}" "rate_limit_hits" "$(( current_hits + 1 ))"
  set_account_state "${alias}" "last_rate_limit" "${now_iso_ts}"
}

###############################################################################
# JWT parsing helpers
###############################################################################

decode_base64url() {
  local input="$1"
  local rem
  rem=$(( ${#input} % 4 ))
  if (( rem == 2 )); then
    input+="=="
  elif (( rem == 3 )); then
    input+="="
  elif (( rem == 1 )); then
    # invalid base64url length
    printf ""
    return 1
  fi
  printf "%s" "${input}" | tr '_-' '/+' | base64 -d 2>/dev/null || true
}

extract_email_from_id_token() {
  local token="$1"
  [[ -n "${token}" ]] || {
    printf ""
    return 0
  }

  local payload_b64 payload_json
  payload_b64="${token#*.}"
  payload_b64="${payload_b64%%.*}"
  payload_json="$(decode_base64url "${payload_b64}")"
  [[ -n "${payload_json}" ]] || {
    printf ""
    return 0
  }

  printf "%s" "${payload_json}" | jq -r '.email // empty' 2>/dev/null || true
}

extract_jwt_claims() {
  # Decode the full JWT payload and return the raw JSON.
  local token="$1"
  [[ -n "${token}" ]] || { printf "{}"; return 0; }

  local payload_b64 payload_json
  payload_b64="${token#*.}"
  payload_b64="${payload_b64%%.*}"
  payload_json="$(decode_base64url "${payload_b64}")"
  [[ -n "${payload_json}" ]] || { printf "{}"; return 0; }

  # Validate it's parseable JSON
  if printf "%s" "${payload_json}" | jq -e '.' >/dev/null 2>&1; then
    printf "%s" "${payload_json}"
  else
    printf "{}"
  fi
}

extract_plan_type() {
  local token="$1"
  local claims
  claims="$(extract_jwt_claims "${token}")"
  printf "%s" "${claims}" | jq -r '.["https://api.openai.com/auth"].chatgpt_plan_type // empty' 2>/dev/null || true
}

extract_account_id_from_token() {
  local token="$1"
  local claims
  claims="$(extract_jwt_claims "${token}")"
  printf "%s" "${claims}" | jq -r '.["https://api.openai.com/auth"].chatgpt_account_id // empty' 2>/dev/null || true
}

get_account_tokens() {
  # Read tokens from an account's credential file.
  local alias="$1"
  local cred_file="${CREDENTIALS_DIR}/${alias}.json"
  [[ -f "${cred_file}" ]] || { printf "{}"; return 0; }

  # If .tokens exists and has at least an access_token, use browser login mode
  if jq -e '.tokens.access_token // empty | length > 0' "${cred_file}" >/dev/null 2>&1; then
    jq -r '.tokens // {}' "${cred_file}" 2>/dev/null || printf "{}"
    return 0
  fi

  # Check if API key mode (no tokens)
  if jq -e 'has("OPENAI_API_KEY")' "${cred_file}" >/dev/null 2>&1; then
    printf '{"mode":"api_key"}'
    return 0
  fi

  jq -r '.tokens // {}' "${cred_file}" 2>/dev/null || printf "{}"
}

get_account_email() {
  local alias="$1"
  local tokens id_token
  tokens="$(get_account_tokens "${alias}")"
  id_token="$(printf "%s" "${tokens}" | jq -r '.id_token // empty' 2>/dev/null || true)"
  extract_email_from_id_token "${id_token}"
}

get_account_plan() {
  local alias="$1"
  local tokens id_token
  tokens="$(get_account_tokens "${alias}")"
  id_token="$(printf "%s" "${tokens}" | jq -r '.id_token // empty' 2>/dev/null || true)"
  extract_plan_type "${id_token}"
}

###############################################################################
# Usage/quota API helpers
###############################################################################

OPENAI_USAGE_URL="https://chatgpt.com/backend-api/wham/usage"
OPENAI_REFRESH_URL="https://auth.openai.com/oauth/token"
OPENAI_CLIENT_ID="app_EMoamEEZ73f0CkXaXp7hrann"

query_usage_api() {
  # Query the OpenAI usage API for a given account.
  # Retries once with a token refresh on 401/403.
  # On success: prints raw JSON response to stdout.
  # On failure: prints "ERROR:<reason>" to stdout where reason is one of:
  #   api_key   — account uses API key mode (no usage API)
  #   no_token  — no access_token available
  #   network   — curl failed (timeout, DNS, connection refused)
  #   auth      — 401/403 even after token refresh
  #   http_NNN  — unexpected HTTP status NNN
  #   parse     — HTTP 200 but response is not valid JSON
  local alias="$1"
  local tokens access_token account_id

  tokens="$(get_account_tokens "${alias}")"

  # API key mode — no usage API available
  if [[ "$(printf "%s" "${tokens}" | jq -r '.mode // empty')" == "api_key" ]]; then
    printf "ERROR:api_key"
    return 0
  fi

  access_token="$(printf "%s" "${tokens}" | jq -r '.access_token // empty')"
  account_id="$(printf "%s" "${tokens}" | jq -r '.account_id // empty')"

  # Fallback: derive account_id from JWT if not stored in tokens
  if [[ -z "${account_id}" ]]; then
    account_id="$(extract_account_id_from_token "${access_token}")"
  fi

  if [[ -z "${access_token}" ]]; then
    printf "ERROR:no_token"
    return 0
  fi

  local response http_code attempt curl_exit
  for attempt in 1 2; do
    curl_exit=0
    response="$(curl -sS --max-time 10 \
      -H "Authorization: Bearer ${access_token}" \
      -H "User-Agent: codex-cli/1.0.0" \
      ${account_id:+-H "chatgpt-account-id: ${account_id}"} \
      -w "\n%{http_code}" \
      "${OPENAI_USAGE_URL}" 2>/dev/null)" || curl_exit=$?

    if [[ "${curl_exit}" -ne 0 || -z "${response}" ]]; then
      printf "ERROR:network"
      return 0
    fi

    # Split response body and HTTP code
    http_code="$(printf "%s" "${response}" | tail -n1)"
    response="$(printf "%s" "${response}" | sed '$d')"

    if [[ "${http_code}" == "200" ]]; then
      if printf "%s" "${response}" | jq -e '.' >/dev/null 2>&1; then
        printf "%s" "${response}"
        return 0
      else
        printf "ERROR:parse"
        return 0
      fi
    fi

    # On 401/403, try refreshing the token and retry once
    if [[ "${attempt}" -eq 1 ]] && [[ "${http_code}" == "401" || "${http_code}" == "403" ]]; then
      if refresh_account_token "${alias}" 2>/dev/null; then
        # Re-read tokens after refresh
        tokens="$(get_account_tokens "${alias}")"
        access_token="$(printf "%s" "${tokens}" | jq -r '.access_token // empty')"
        if [[ -z "${access_token}" ]]; then
          printf "ERROR:auth"
          return 0
        fi
      else
        printf "ERROR:auth"
        return 0
      fi
    else
      # Second attempt still got 401/403, or non-auth error
      if [[ "${http_code}" == "401" || "${http_code}" == "403" ]]; then
        printf "ERROR:auth"
      else
        printf "ERROR:http_%s" "${http_code}"
      fi
      return 0
    fi
  done

  printf "ERROR:network"
}

refresh_account_token() {
  # Refresh tokens for a given account using refresh_token.
  # Updates the credential file in-place on success.
  # Returns: 0 on success, 1 on failure.
  local alias="$1"
  local cred_file="${CREDENTIALS_DIR}/${alias}.json"
  [[ -f "${cred_file}" ]] || return 1

  local tokens refresh_token
  tokens="$(get_account_tokens "${alias}")"

  if [[ "$(printf "%s" "${tokens}" | jq -r '.mode // empty')" == "api_key" ]]; then
    log_warn "Account '${alias}' uses API key mode — token refresh not applicable"
    return 1
  fi

  refresh_token="$(printf "%s" "${tokens}" | jq -r '.refresh_token // empty')"
  [[ -n "${refresh_token}" ]] || {
    log_warn "Account '${alias}' has no refresh_token"
    return 1
  }

  local response http_code
  response="$(curl -sS --max-time 15 \
    -X POST "${OPENAI_REFRESH_URL}" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    --data-urlencode "grant_type=refresh_token" \
    --data-urlencode "refresh_token=${refresh_token}" \
    --data-urlencode "client_id=${OPENAI_CLIENT_ID}" \
    -w "\n%{http_code}" \
    2>/dev/null || true)"

  http_code="$(printf "%s" "${response}" | tail -n1)"
  response="$(printf "%s" "${response}" | sed '$d')"

  if [[ "${http_code}" != "200" ]]; then
    log_warn "Token refresh failed for '${alias}' (HTTP ${http_code})"
    return 1
  fi

  # Validate response has tokens
  local new_id_token new_access_token new_refresh_token
  new_id_token="$(printf "%s" "${response}" | jq -r '.id_token // empty' 2>/dev/null || true)"
  new_access_token="$(printf "%s" "${response}" | jq -r '.access_token // empty' 2>/dev/null || true)"
  new_refresh_token="$(printf "%s" "${response}" | jq -r '.refresh_token // empty' 2>/dev/null || true)"

  if [[ -z "${new_access_token}" ]]; then
    log_warn "Token refresh for '${alias}' returned no access_token"
    return 1
  fi

  # Preserve existing id_token if the refresh response did not include one
  local existing_id_token
  if [[ -z "${new_id_token}" ]]; then
    existing_id_token="$(jq -r '.tokens.id_token // empty' "${cred_file}" 2>/dev/null || true)"
    new_id_token="${existing_id_token}"
  fi

  # Update credential file — preserve existing fields, update tokens
  local tmp_file
  tmp_file="$(mktemp "${cred_file}.tmp.XXXXXX")"

  if jq --arg id "${new_id_token}" \
     --arg access "${new_access_token}" \
     --arg refresh "${new_refresh_token:-${refresh_token}}" \
     '.tokens.id_token = $id | .tokens.access_token = $access | .tokens.refresh_token = $refresh' \
     "${cred_file}" > "${tmp_file}" 2>/dev/null; then
    if jq -e '.' "${tmp_file}" >/dev/null 2>&1; then
      chmod 600 "${tmp_file}"
      mv -f "${tmp_file}" "${cred_file}"
      return 0
    fi
  fi

  rm -f "${tmp_file}"
  log_warn "Failed to update credential file for '${alias}'"
  return 1
}

parse_usage_percent() {
  # Extract primary window used_percent from usage JSON.
  local usage_json="$1"
  [[ -n "${usage_json}" ]] || { printf "0"; return 0; }
  local pct
  pct="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.used_percent // 0' 2>/dev/null || true)"
  [[ -n "${pct}" && "${pct}" != "null" ]] || pct="0"
  printf "%s" "${pct}"
}

parse_usage_reset_at() {
  # Extract primary window reset_at ISO timestamp from usage JSON.
  local usage_json="$1"
  [[ -n "${usage_json}" ]] || { printf ""; return 0; }
  printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.reset_at // empty' 2>/dev/null || true
}

parse_reset_epoch() {
  # Convert a reset_at value to a Unix epoch.
  # Handles: Unix epoch (integer/float), ISO 8601 timestamps, empty.
  local reset_at="$1"
  [[ -n "${reset_at}" ]] || { printf "0"; return 0; }

  # If it's already a numeric epoch (integer or float like 1712345678 or 1712345678.123)
  if [[ "${reset_at}" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    # Strip fractional part
    printf "%s" "${reset_at%%.*}"
    return 0
  fi

  # Try ISO 8601 parsing (GNU date, then BSD date)
  local epoch
  epoch="$(date -d "${reset_at}" +%s 2>/dev/null)" && { printf "%s" "${epoch}"; return 0; }
  epoch="$(date -j -f "%Y-%m-%dT%H:%M:%S" "${reset_at%%.*}" +%s 2>/dev/null)" && { printf "%s" "${epoch}"; return 0; }

  printf "0"
}

format_usage_bar() {
  # Render a text-based usage bar: [████████░░] 80%
  local percent="$1"
  local width="${2:-10}"
  # Ensure percent is an integer
  percent="${percent%%.*}"
  [[ "${percent}" =~ ^[0-9]+$ ]] || percent=0
  (( percent > 100 )) && percent=100

  local filled=$(( percent * width / 100 ))
  local empty=$(( width - filled ))

  local bar=""
  local i
  for (( i=0; i<filled; i++ )); do bar+="█"; done
  for (( i=0; i<empty; i++ )); do bar+="░"; done

  local color="${GREEN}"
  if (( percent >= 90 )); then
    color="${RED}"
  elif (( percent >= 70 )); then
    color="${YELLOW}"
  fi

  printf "%b[%s]%b %3d%%" "${color}" "${bar}" "${RESET}" "${percent}"
}

###############################################################################
# Bootstrap/init helpers
###############################################################################

ensure_account_dirs() {
  mkdir -p "${ACCOUNTS_DIR}" "${CREDENTIALS_DIR}" "${LOCK_DIR}"
  chmod 700 "${ACCOUNTS_DIR}" "${CREDENTIALS_DIR}"
  touch "${LOCK_FILE}"
}

initialize_state_files() {
  local tmp

  if [[ ! -f "${STATE_FILE}" ]]; then
    tmp="$(mktemp "${STATE_FILE}.tmp.XXXXXX")"
    printf '{"accounts":{}}\n' > "${tmp}"
    mv -f "${tmp}" "${STATE_FILE}"
  fi

  [[ -f "${ORDER_FILE}" ]] || : > "${ORDER_FILE}"
  [[ -f "${ACTIVE_FILE}" ]] || : > "${ACTIVE_FILE}"
}

###############################################################################
# Command implementations
###############################################################################

cmd_init() {
  check_prerequisites
  ensure_account_dirs

  if [[ ! -f "${CONFIG_FILE}" ]]; then
    write_default_config
  fi

  initialize_state_files
  backup_original_auth_if_needed

  log_success "Initialized ${ACCOUNTS_DIR}"
  log_info "Credentials directory: ${CREDENTIALS_DIR}"
  log_info "State file: ${STATE_FILE}"
}

cmd_add() {
  require_initialized
  load_config

  local alias=""
  local force=0
  local group=""

  if (( $# < 1 )); then
    die "Usage: ${SCRIPT_NAME} add <alias> [--force]"
  fi

  alias="$1"
  shift

  while (( $# > 0 )); do
    case "$1" in
      --force) force=1 ;;
      --group=*) group="${1#--group=}" ;;
      --group)
        shift
        [[ $# -gt 0 ]] || die "--group requires value"
        group="$1"
        ;;
      *) die "Unknown flag for add: $1" ;;
    esac
    shift
  done

  validate_alias "${alias}" || die "Invalid alias '${alias}'. Use only [a-zA-Z0-9_-]."

  if account_exists "${alias}" && (( force == 0 )); then
    die "Alias '${alias}' already exists. Use --force to replace."
  fi

   local tmp_home
  tmp_home="$(mktemp -d "${HOME_DIR}/.codex-tmp.${alias}.XXXXXX")"

  # Use a file to pass tmp_home path to trap safely (avoids unbound variable under set -u after function returns)
  local tmp_home_ref="${HOME_DIR}/.codex-tmp.${alias}.ref"
  printf '%s' "${tmp_home}" > "${tmp_home_ref}"
  trap 'rm -rf "$(cat "'"${tmp_home_ref}"'" 2>/dev/null)" "'"${tmp_home_ref}"'" >/dev/null 2>&1 || true' EXIT

  local source_codex_home
  source_codex_home="${CODEX_HOME:-${HOME_DIR}/.codex}"
  if [[ -f "${source_codex_home}/config.toml" ]]; then
    cp -a "${source_codex_home}/config.toml" "${tmp_home}/config.toml"
  fi

  log_info "Starting interactive login for alias '${alias}'..."
  log_info "A browser may open. Complete login then return to terminal."

  CODEX_HOME="${tmp_home}" "${CODEX_BIN}" login

  [[ -f "${tmp_home}/auth.json" ]] || die "Login completed but auth.json not found in temporary CODEX_HOME"

  cp -f "${tmp_home}/auth.json" "${CREDENTIALS_DIR}/${alias}.json"
  chmod 600 "${CREDENTIALS_DIR}/${alias}.json"

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_add_state" "${alias}" "${group}")
  with_lock "${lock_cmd}"

  # Clean up temp dir manually now and clear the EXIT trap (avoids unbound-variable issue under set -u)
  trap - EXIT
  rm -rf "${tmp_home}" "${tmp_home_ref}" >/dev/null 2>&1 || true

  log_success "Added account '${alias}'"
}

internal_add_state() {
  local alias="$1"
  local group="${2:-}"
  init_account_state_entry "${alias}" "${group}"
  append_order "${alias}"
}

cmd_import() {
  require_initialized
  load_config

  if (( $# != 2 )); then
    die "Usage: ${SCRIPT_NAME} import <alias> <path>"
  fi

  local alias="$1"
  local path="$2"

  validate_alias "${alias}" || die "Invalid alias '${alias}'. Use only [a-zA-Z0-9_-]."
  [[ -f "${path}" ]] || die "Credential file not found: ${path}"

  jq -e 'has("auth_mode") and has("tokens")' "${path}" >/dev/null 2>&1 || \
    die "Invalid auth file. Expected JSON with keys: auth_mode, tokens"

  cp -f "${path}" "${CREDENTIALS_DIR}/${alias}.json"
  chmod 600 "${CREDENTIALS_DIR}/${alias}.json"

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_add_state" "${alias}")
  with_lock "${lock_cmd}"

  local account_id id_token email
  account_id="$(jq -r '.tokens.account_id // ""' "${CREDENTIALS_DIR}/${alias}.json")"
  id_token="$(jq -r '.tokens.id_token // ""' "${CREDENTIALS_DIR}/${alias}.json")"
  email="$(extract_email_from_id_token "${id_token}")"

  log_success "Imported account '${alias}'"
  printf "  account_id: %s\n" "${account_id:-unknown}"
  printf "  email: %s\n" "${email:-unknown}"
}

cmd_remove() {
  require_initialized
  load_config

  if (( $# != 1 )); then
    die "Usage: ${SCRIPT_NAME} remove <alias>"
  fi

  local alias="$1"
  validate_alias "${alias}" || die "Invalid alias '${alias}'."
  account_exists "${alias}" || die "Alias '${alias}' does not exist"

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_remove" "${alias}")
  with_lock "${lock_cmd}"

  log_success "Removed account '${alias}'"
}

internal_remove() {
  local alias="$1"
  local active
  active="$(get_active)"

  mapfile -t all_aliases < <(get_order)
  if (( ${#all_aliases[@]} <= 1 )) && [[ "${active}" == "${alias}" ]]; then
    die "Cannot remove active account '${alias}' because it is the only account"
  fi

  if [[ "${active}" == "${alias}" ]]; then
    local next
    next=""
    local a
    for a in "${all_aliases[@]}"; do
      [[ "${a}" == "${alias}" ]] && continue
      if [[ -f "${CREDENTIALS_DIR}/${a}.json" ]] && ! is_on_cooldown "${a}"; then
        next="${a}"
        break
      fi
    done
    if [[ -z "${next}" ]]; then
      for a in "${all_aliases[@]}"; do
        [[ "${a}" == "${alias}" ]] && continue
        if [[ -f "${CREDENTIALS_DIR}/${a}.json" ]]; then
          next="${a}"
          log_warn "No non-cooldown account available. Switching to '${next}' anyway."
          break
        fi
      done
    fi
    [[ -n "${next}" ]] || die "Cannot rotate away from '${alias}' before removal"
    ensure_symlink "${next}"
    set_active "${next}"
    set_account_state "${next}" "last_used" "$(now_iso)"
  fi

  rm -f "${CREDENTIALS_DIR}/${alias}.json"
  remove_from_order "${alias}"
  delete_account_state_entry "${alias}"

  if [[ -L "${CODEX_AUTH}" ]]; then
    local target
    target="$(readlink "${CODEX_AUTH}" || true)"
    if [[ "${target}" == *"/${alias}.json" ]]; then
      local now_active
      now_active="$(get_active)"
      if [[ -n "${now_active}" && -f "${CREDENTIALS_DIR}/${now_active}.json" ]]; then
        ensure_symlink "${now_active}"
      else
        rm -f "${CODEX_AUTH}"
      fi
    fi
  fi
}

render_status_label() {
  local alias="$1"
  local active="$2"

  if [[ ! -f "${CREDENTIALS_DIR}/${alias}.json" ]]; then
    printf "%b✗ NO CREDS%b" "${RED}" "${RESET}"
    return 0
  fi

  if [[ "${alias}" == "${active}" ]]; then
    printf "%b● ACTIVE%b" "${GREEN}" "${RESET}"
    return 0
  fi

  if is_on_cooldown "${alias}"; then
    printf "%b⏸ COOLDOWN%b" "${YELLOW}" "${RESET}"
    return 0
  fi

  printf "%b✓ AVAILABLE%b" "${WHITE}" "${RESET}"
}

cmd_list() {
  require_initialized
  load_config

  local json_output=0
  local args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --json) json_output=1 ;;
      *) args+=("${arg}") ;;
    esac
  done

  mapfile -t all_aliases < <(get_order)
  local active
  active="$(get_active)"
  local show_group=0
  if [[ -f "${STATE_FILE}" ]]; then
    if jq -e '[.accounts[].group // empty] | map(select(length > 0)) | length > 0' "${STATE_FILE}" >/dev/null 2>&1; then
      show_group=1
    fi
  fi

  if (( json_output == 1 )); then
    local json_result alias status_value uses last_used cooldown_secs email plan active_json alias_json
    json_result="$(jq -n '[]')"

    for alias in "${all_aliases[@]}"; do
      uses="$(get_account_state "${alias}" "total_uses")"
      uses="${uses:-0}"
      [[ "${uses}" =~ ^[0-9]+$ ]] || uses=0
      last_used="$(get_account_state "${alias}" "last_used")"
      cooldown_secs="$(cooldown_remaining "${alias}")"
      email="$(get_account_email "${alias}")"
      plan="$(get_account_plan "${alias}")"
      email="${email:-unknown}"
      plan="${plan:-unknown}"

      status_value="ready"
      active_json="false"
      if [[ ! -f "${CREDENTIALS_DIR}/${alias}.json" ]]; then
        status_value="missing_credentials"
      elif [[ "${alias}" == "${active}" ]]; then
        status_value="active"
        active_json="true"
      elif (( cooldown_secs > 0 )); then
        status_value="cooldown"
      fi

      alias_json="$(jq -n \
        --arg alias "${alias}" \
        --argjson active "${active_json}" \
        --arg email "${email}" \
        --arg status "${status_value}" \
        --argjson uses "${uses}" \
        --arg plan "${plan}" \
        --arg last_used "${last_used}" \
        --argjson cooldown "${cooldown_secs}" \
        '{
          alias: $alias,
          active: $active,
          email: $email,
          status: $status,
          uses: $uses,
          plan: $plan,
          last_used: (if $last_used == "" then null else $last_used end),
          cooldown: (if $cooldown > 0 then $cooldown else null end)
        }')"

      json_result="$(jq --argjson item "${alias_json}" '. += [$item]' <<< "${json_result}")"
    done

    printf '%s\n' "${json_result}"
    return 0
  fi

  if (( show_group == 1 )); then
    printf "%-15s %-25s %-12s %-16s %-6s %-10s %-10s %-8s\n" \
      "ALIAS" "EMAIL" "GROUP" "STATUS" "USES" "PLAN" "LAST USED" "COOLDOWN"
    printf "%-15s %-25s %-12s %-16s %-6s %-10s %-10s %-8s\n" \
      "───────────────" "─────────────────────────" "────────────" "────────────────" "──────" "──────────" "──────────" "────────"
  else
    printf "%-15s %-25s %-16s %-6s %-10s %-10s %-8s\n" \
      "ALIAS" "EMAIL" "STATUS" "USES" "PLAN" "LAST USED" "COOLDOWN"
    printf "%-15s %-25s %-16s %-6s %-10s %-10s %-8s\n" \
      "───────────────" "─────────────────────────" "────────────────" "──────" "──────────" "──────────" "────────"
  fi

  if (( ${#all_aliases[@]} == 0 )); then
    if (( show_group == 1 )); then
      printf "%-15s %-25s %-12s %-16s %-6s %-10s %-10s %-8s\n" "(none)" "-" "-" "-" "-" "-" "-" "-"
    else
      printf "%-15s %-25s %-16s %-6s %-10s %-10s %-8s\n" "(none)" "-" "-" "-" "-" "-" "-"
    fi
    return 0
  fi

  local alias status uses last_used last_epoch last_str cooldown_secs cooldown_str email plan group
  for alias in "${all_aliases[@]}"; do
    status="$(render_status_label "${alias}" "${active}")"
    uses="$(get_account_state "${alias}" "total_uses")"
    uses="${uses:-0}"
    last_used="$(get_account_state "${alias}" "last_used")"
    last_epoch="$(iso_to_epoch "${last_used}")"
    last_str="$(format_time_ago "${last_epoch}")"
    cooldown_secs="$(cooldown_remaining "${alias}")"
    email="$(get_account_email "${alias}")"
    plan="$(get_account_plan "${alias}")"
    group="$(get_account_group "${alias}")"

    # Truncate email for display
    if [[ ${#email} -gt 24 ]]; then
      email="${email:0:21}..."
    fi

    if (( cooldown_secs > 0 )); then
      cooldown_str="$(format_duration "${cooldown_secs}")"
    else
      cooldown_str="-"
    fi

    if (( show_group == 1 )); then
      printf "%-15s %-25s %-12s %-16b %-6s %-10s %-10s %-8s\n" \
        "${alias}" "${email:-unknown}" "${group:-}" "${status}" "${uses}" "${plan:-?}" "${last_str}" "${cooldown_str}"
    else
      printf "%-15s %-25s %-16b %-6s %-10s %-10s %-8s\n" \
        "${alias}" "${email:-unknown}" "${status}" "${uses}" "${plan:-?}" "${last_str}" "${cooldown_str}"
    fi
  done
}

cmd_switch() {
  require_initialized
  load_config

  if (( $# < 1 )); then
    die "Usage: ${SCRIPT_NAME} switch <alias> [--force]"
  fi

  local alias="$1"
  shift
  local force=0

  while (( $# > 0 )); do
    case "$1" in
      --force) force=1 ;;
      *) die "Unknown flag for switch: $1" ;;
    esac
    shift
  done

  validate_alias "${alias}" || die "Invalid alias '${alias}'."
  account_exists "${alias}" || die "Alias '${alias}' does not exist or has no credentials"

  if is_on_cooldown "${alias}" && (( force == 0 )); then
    local rem
    rem="$(cooldown_remaining "${alias}")"
    die "Alias '${alias}' is on cooldown for $(format_duration "${rem}"). Use --force to switch anyway."
  fi

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_switch" "${alias}")
  with_lock "${lock_cmd}"

  log_success "Switched active account to '${alias}'"
}

internal_switch() {
  local alias="$1"
  backup_original_auth_if_needed
  ensure_symlink "${alias}"
  set_active "${alias}"
  set_account_state "${alias}" "last_used" "$(now_iso)"
}

cmd_status() {
  require_initialized
  load_config

  local json_output=0
  local args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --json) json_output=1 ;;
      *) args+=("${arg}") ;;
    esac
  done

  mapfile -t all_aliases < <(get_order)
  local active
  active="$(get_active)"

  if (( json_output == 1 )); then
    local accounts_json alias status_value uses last_used cooldown_secs email plan active_json alias_json
    local quota_aware_json="false"
    (( QUOTA_AWARE_ROTATION == 1 )) && quota_aware_json="true"

    accounts_json="$(jq -n '[]')"
    for alias in "${all_aliases[@]}"; do
      uses="$(get_account_state "${alias}" "total_uses")"
      uses="${uses:-0}"
      [[ "${uses}" =~ ^[0-9]+$ ]] || uses=0
      last_used="$(get_account_state "${alias}" "last_used")"
      cooldown_secs="$(cooldown_remaining "${alias}")"
      email="$(get_account_email "${alias}")"
      plan="$(get_account_plan "${alias}")"
      email="${email:-unknown}"
      plan="${plan:-unknown}"

      status_value="ready"
      active_json="false"
      if [[ ! -f "${CREDENTIALS_DIR}/${alias}.json" ]]; then
        status_value="missing_credentials"
      elif [[ "${alias}" == "${active}" ]]; then
        status_value="active"
        active_json="true"
      elif (( cooldown_secs > 0 )); then
        status_value="cooldown"
      fi

      alias_json="$(jq -n \
        --arg alias "${alias}" \
        --argjson active "${active_json}" \
        --arg email "${email}" \
        --arg status "${status_value}" \
        --argjson uses "${uses}" \
        --arg plan "${plan}" \
        --arg last_used "${last_used}" \
        --argjson cooldown "${cooldown_secs}" \
        '{
          alias: $alias,
          active: $active,
          email: $email,
          status: $status,
          uses: $uses,
          plan: $plan,
          last_used: (if $last_used == "" then null else $last_used end),
          cooldown: (if $cooldown > 0 then $cooldown else null end)
        }')"

      accounts_json="$(jq --argjson item "${alias_json}" '. += [$item]' <<< "${accounts_json}")"
    done

    jq -n \
      --arg version "${SCRIPT_VERSION}" \
      --argjson rotation_interval "${ROTATION_INTERVAL}" \
      --argjson hourly_cooldown "${HOURLY_COOLDOWN}" \
      --argjson daily_cooldown "${DAILY_COOLDOWN}" \
      --argjson weekly_cooldown "${WEEKLY_COOLDOWN}" \
      --argjson max_retries "${MAX_RETRIES}" \
      --argjson quota_aware_rotation "${quota_aware_json}" \
      --argjson accounts "${accounts_json}" \
      '{
        version: $version,
        config: {
          rotation_interval: $rotation_interval,
          hourly_cooldown: $hourly_cooldown,
          daily_cooldown: $daily_cooldown,
          weekly_cooldown: $weekly_cooldown,
          max_retries: $max_retries,
          quota_aware_rotation: $quota_aware_rotation
        },
        accounts: $accounts
      }'
    return 0
  fi

  printf "\n"
  printf "%b╔══════════════════════════════════════════════════════════════════════════════╗%b\n" "${BLUE}" "${RESET}"
  printf "%b║              Codex Account Rotation Manager v%-6s                          ║%b\n" "${BLUE}" "${SCRIPT_VERSION}" "${RESET}"
  printf "%b╠══════════════════════════════════════════════════════════════════════════════╣%b\n" "${BLUE}" "${RESET}"

  local available_count=0
  local total_accounts="${#all_aliases[@]}"

  if (( total_accounts == 0 )); then
    printf "%b║  (no accounts configured)                                                  ║%b\n" "${BLUE}" "${RESET}"
  else
    for alias in "${all_aliases[@]}"; do
      local marker email plan status uses last_used last_epoch ago cd_secs cd_left

      if [[ "${alias}" == "${active}" ]]; then
        marker="▶"
      else
        marker=" "
      fi

      email="$(get_account_email "${alias}")"
      plan="$(get_account_plan "${alias}")"
      status="$(render_status_label "${alias}" "${active}")"
      uses="$(get_account_state "${alias}" "total_uses")"
      uses="${uses:-0}"
      last_used="$(get_account_state "${alias}" "last_used")"
      last_epoch="$(iso_to_epoch "${last_used}")"
      ago="$(format_time_ago "${last_epoch}")"
      cd_secs="$(cooldown_remaining "${alias}")"
      if (( cd_secs > 0 )); then
        cd_left="$(format_duration "${cd_secs}")"
      else
        cd_left="-"
      fi

      if [[ -f "${CREDENTIALS_DIR}/${alias}.json" ]] && (( cd_secs == 0 )); then
        ((available_count+=1))
      fi

      printf " %s %-12.12s  %-24.24s  %-8.8s  %-11b  %4s  %-8.8s  %-7.7s\n" \
        "${marker}" "${alias}" "${email:-unknown}" "${plan:-?}" "${status}" "${uses}" "${ago}" "${cd_left}"
    done
  fi

  printf "%b╠══════════════════════════════════════════════════════════════════════════════╣%b\n" "${BLUE}" "${RESET}"
  printf "%b║  Rotation: %-6s  Accounts: %-3s  Available: %-3s                              ║%b\n" \
    "${BLUE}" "$(format_duration "${ROTATION_INTERVAL}")" "${total_accounts}" "${available_count}" "${RESET}"
  printf "%b║  Cooldowns: hourly=%-5s daily=%-6s weekly=%-6s                          ║%b\n" \
    "${BLUE}" "$(format_duration "${HOURLY_COOLDOWN}")" "$(format_duration "${DAILY_COOLDOWN}")" "$(format_duration "${WEEKLY_COOLDOWN}")" "${RESET}"
  printf "%b╚══════════════════════════════════════════════════════════════════════════════╝%b\n" "${BLUE}" "${RESET}"
  printf "\n"
}

ensure_active_ready() {
  local active
  active="$(get_active)"

  if [[ -z "${active}" || ! -f "${CREDENTIALS_DIR}/${active}.json" ]]; then
    local next
    next="$(get_next_available)"
    [[ -n "${next}" ]] || die "No available account with credentials"
    log_warn "Active account missing/invalid. Switching to '${next}'."
    internal_switch "${next}"
    active="${next}"
  fi

  if is_on_cooldown "${active}"; then
    local next
    next="$(get_next_available)"
    if [[ -n "${next}" && "${next}" != "${active}" ]]; then
      log_warn "Active account '${active}' on cooldown. Rotating to '${next}'."
      internal_switch "${next}"
    else
      die "All accounts are on cooldown or unavailable"
    fi
  fi

  validate_symlink || {
    local current
    current="$(get_active)"
    [[ -n "${current}" ]] || die "No active account set"
    log_warn "Auth symlink invalid. Rebuilding symlink for '${current}'."
    ensure_symlink "${current}"
  }
}

increment_use_counter() {
  local alias="$1"
  local uses
  uses="$(get_account_state "${alias}" "total_uses")"
  uses="${uses:-0}"
  [[ "${uses}" =~ ^[0-9]+$ ]] || uses=0
  set_account_state "${alias}" "total_uses" "$(( uses + 1 ))"
  set_account_state "${alias}" "last_used" "$(now_iso)"
}

run_codex_capture_and_retry() {
  local -a codex_args=("$@")
  local attempt=0

  while :; do
    local out_file
    out_file="$(mktemp "${HOME_DIR}/.codex-rotate.run.XXXXXX.log")"

    set +e
    "${CODEX_BIN}" "${codex_args[@]}" 2>&1 | tee "${out_file}"
    local cmd_exit=${PIPESTATUS[0]}
    set -e

    if (( cmd_exit != 0 )) && detect_rate_limit "${out_file}"; then
      local current cd_seconds next old_alias
      current="$(get_active)"
      old_alias="${current}"
      cd_seconds="$(classify_cooldown "${out_file}")"

      local lock_cmd
      lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_mark_rate_limit" "${current}" "${cd_seconds}")
      with_lock "${lock_cmd}"

      printf "[codex-rotate] ⚠ Rate limit hit on %s. Rotating to next account...\n" "${current}" >&2

      next="$(get_next_available)"
      if [[ -z "${next}" || "${next}" == "${current}" ]]; then
        rm -f "${out_file}"
        die "Rate limit detected on '${current}' but no alternate account is available"
      fi

      local switch_cmd
      switch_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_switch" "${next}")
      with_lock "${switch_cmd}"
      send_notification "codex-rotate" "Switched from '${old_alias}' to '${next}' (rate limit hit)"

      rm -f "${out_file}"
      attempt=$(( attempt + 1 ))
      if (( attempt > MAX_RETRIES )); then
        die "Exceeded MAX_RETRIES (${MAX_RETRIES}) after rate limit rotations"
      fi
      continue
    fi

    rm -f "${out_file}"

    if (( cmd_exit == 0 )); then
      local active
      active="$(get_active)"
      local lock_cmd
      lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_increment_use" "${active}")
      with_lock "${lock_cmd}"
    fi

    return "${cmd_exit}"
  done
}

internal_mark_rate_limit() {
  local alias="$1"
  local seconds="$2"
  mark_rate_limit_hit "${alias}" "${seconds}"
}

internal_increment_use() {
  local alias="$1"
  increment_use_counter "${alias}"
}

cmd_run() {
  require_initialized
  load_config

  local group=""
  local -a cmd_args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --group=*) group="${arg#--group=}" ;;
      --group)
        die "Use --group=<name>"
        ;;
      *) cmd_args+=("${arg}") ;;
    esac
  done

  if [[ -n "${group}" ]]; then
    export CODEX_ROTATE__GROUP="${group}"
  else
    unset CODEX_ROTATE__GROUP || true
  fi

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_ensure_active_ready")
  with_lock "${lock_cmd}"

  # Interactive mode detection:
  # - no args: run codex directly (full TTY)
  # - args without 'exec': treat as potentially interactive and run direct
  # - args with 'exec': capture output for RL detection and retry
  local interactive=0
  if (( ${#cmd_args[@]} == 0 )); then
    interactive=1
  else
    local has_exec=0
    for arg in "${cmd_args[@]}"; do
      if [[ "${arg}" == "exec" ]]; then
        has_exec=1
        break
      fi
    done
    if (( has_exec == 0 )); then
      interactive=1
    fi
  fi

  if (( interactive == 1 )); then
    # For interactive/TUI mode we cannot pipe output without destroying the TTY.
    # Strategy: run codex directly (full TTY), capture exit code, then scan a
    # background tee of stderr to a temp file for rate-limit signals.
    # If codex exits with a non-zero code AND a rate-limit pattern is detected
    # in the last N lines written to a side-channel stderr log, rotate and retry.
    local attempt=0
    while :; do
      local err_file
      err_file="$(mktemp "${HOME_DIR}/.codex-rotate.interactive.XXXXXX.log")"

      set +e
      # Run codex with TTY intact for stdout, but tee stderr to our log file
      # using process substitution so the user still sees all stderr output.
      { "${CODEX_BIN}" "${cmd_args[@]}" 2> >(tee "${err_file}" >&2); }
      local cmd_exit=$?
      set -e

      # Give the tee sub-process a moment to flush
      sleep 0.1

      if (( cmd_exit != 0 )) && detect_rate_limit "${err_file}"; then
        local current cd_seconds next old_alias
        current="$(get_active)"
        old_alias="${current}"
        cd_seconds="$(classify_cooldown "${err_file}")"

        local lock_cmd
        lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_mark_rate_limit" "${current}" "${cd_seconds}")
        with_lock "${lock_cmd}"

        printf "[codex-rotate] ⚠ Rate limit hit on '%s'. Rotating to next account...\n" "${current}" >&2

        next="$(get_next_available)"
        if [[ -n "${next}" && "${next}" != "${current}" ]]; then
          local switch_cmd
          switch_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_switch" "${next}")
          with_lock "${switch_cmd}"
          send_notification "codex-rotate" "Switched from '${old_alias}' to '${next}' (rate limit hit)"

          rm -f "${err_file}"
          attempt=$(( attempt + 1 ))
          if (( attempt > MAX_RETRIES )); then
            die "Exceeded MAX_RETRIES (${MAX_RETRIES}) after rate limit rotations"
          fi
          printf "[codex-rotate] ↩ Retrying on '%s'...\n" "${next}" >&2
          continue
        else
          rm -f "${err_file}"
          die "Rate limit on '${current}' but no alternate account available"
        fi
      fi

      rm -f "${err_file}"

      if (( cmd_exit == 0 )); then
        local active
        active="$(get_active)"
        local update_cmd
        update_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_increment_use" "${active}")
        with_lock "${update_cmd}"
      fi

      return "${cmd_exit}"
    done
    return
  fi

  run_codex_capture_and_retry "${cmd_args[@]}"
}

internal_ensure_active_ready() {
  ensure_active_ready
}

cmd_auto() {
  require_initialized
  load_config

  local group=""
  local -a cmd_args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --group=*) group="${arg#--group=}" ;;
      --group)
        die "Use --group=<name>"
        ;;
      *) cmd_args+=("${arg}") ;;
    esac
  done

  if [[ -n "${group}" ]]; then
    export CODEX_ROTATE__GROUP="${group}"
  else
    unset CODEX_ROTATE__GROUP || true
  fi

  # Enable quota-aware rotation for auto mode.
  # Export as environment variable so it survives the with_lock subprocess
  # (flock -c spawns a new process that re-enters main→load_config).
  QUOTA_AWARE_ROTATION=1
  export CODEX_ROTATE__QUOTA_AWARE=1

  local lock_cmd
  lock_cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_auto_preflight")
  with_lock "${lock_cmd}"

  cmd_run "${cmd_args[@]}"
}

internal_auto_preflight() {
  ensure_active_ready

  local active last_used last_epoch now diff
  active="$(get_active)"
  [[ -n "${active}" ]] || return 0

  last_used="$(get_account_state "${active}" "last_used")"
  last_epoch="$(iso_to_epoch "${last_used}")"
  now="$(now_epoch)"

  if (( last_epoch > 0 )); then
    diff=$(( now - last_epoch ))
    if (( diff > ROTATION_INTERVAL )); then
      local next
      next="$(get_next_available)"
      if [[ -n "${next}" && "${next}" != "${active}" ]]; then
        log_info "Rotation interval exceeded ($(format_duration "${diff}")). Switching '${active}' -> '${next}'."
        internal_switch "${next}"
      fi
    fi
  fi
}

cmd_cooldown() {
  require_initialized
  load_config

  if (( $# < 1 )); then
    die "Usage: ${SCRIPT_NAME} cooldown <alias> [--hours N | --days N | --weeks N]"
  fi

  local alias="$1"
  shift

  validate_alias "${alias}" || die "Invalid alias '${alias}'."
  account_exists "${alias}" || die "Alias '${alias}' not found"

  local seconds="${HOURLY_COOLDOWN}"

  while (( $# > 0 )); do
    case "$1" in
      --hours)
        shift
        [[ $# -gt 0 ]] || die "--hours requires value"
        [[ "$1" =~ ^[0-9]+$ ]] || die "--hours value must be integer"
        seconds=$(( $1 * 3600 ))
        ;;
      --days)
        shift
        [[ $# -gt 0 ]] || die "--days requires value"
        [[ "$1" =~ ^[0-9]+$ ]] || die "--days value must be integer"
        seconds=$(( $1 * 86400 ))
        ;;
      --weeks)
        shift
        [[ $# -gt 0 ]] || die "--weeks requires value"
        [[ "$1" =~ ^[0-9]+$ ]] || die "--weeks value must be integer"
        seconds=$(( $1 * 604800 ))
        ;;
      *)
        die "Unknown flag for cooldown: $1"
        ;;
    esac
    shift
  done

  local cmd
  cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_cooldown" "${alias}" "${seconds}")
  with_lock "${cmd}"

  log_success "Account '${alias}' put on cooldown for $(format_duration "${seconds}")"
}

internal_cooldown() {
  local alias="$1"
  local seconds="$2"
  mark_rate_limit_hit "${alias}" "${seconds}"
}

cmd_uncooldown() {
  require_initialized
  load_config

  if (( $# != 1 )); then
    die "Usage: ${SCRIPT_NAME} uncooldown <alias>"
  fi

  local alias="$1"
  validate_alias "${alias}" || die "Invalid alias '${alias}'."
  account_exists "${alias}" || die "Alias '${alias}' not found"

  local cmd
  cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_uncooldown" "${alias}")
  with_lock "${cmd}"

  log_success "Cooldown cleared for '${alias}'"
}

internal_group_set() {
  local alias="$1"
  local group="$2"
  set_account_group "${alias}" "${group}"
}

internal_group_unset() {
  local alias="$1"
  local tmp="${STATE_FILE}.tmp.$$"
  jq --arg a "${alias}" '.accounts[$a].group = ""' "${STATE_FILE}" > "${tmp}" && mv "${tmp}" "${STATE_FILE}"
}

cmd_group() {
  local subcmd="${1:-}"
  shift || true

  case "${subcmd}" in
    set)
      local alias="${1:-}"
      local group="${2:-}"
      [[ -z "${alias}" ]] && die "Usage: ${SCRIPT_NAME} group set <alias> <group>"
      [[ -z "${group}" ]] && die "Usage: ${SCRIPT_NAME} group set <alias> <group>"
      require_initialized
      load_config
      [[ ! -f "${CREDENTIALS_DIR}/${alias}.json" ]] && die "Account '${alias}' not found."
      local cmd
      cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_group_set" "${alias}" "${group}")
      with_lock "${cmd}"
      log_info "Account '${alias}' added to group '${group}'."
      ;;
    unset)
      local alias="${1:-}"
      [[ -z "${alias}" ]] && die "Usage: ${SCRIPT_NAME} group unset <alias>"
      require_initialized
      load_config
      [[ ! -f "${CREDENTIALS_DIR}/${alias}.json" ]] && die "Account '${alias}' not found."
      local cmd
      cmd=$(printf '%q ' "${BASH_SOURCE[0]}" "__internal_group_unset" "${alias}")
      with_lock "${cmd}"
      log_info "Group cleared for account '${alias}'."
      ;;
    list)
      require_initialized
      load_config
      local groups=()
      if [[ -f "${STATE_FILE}" ]]; then
        while IFS= read -r g; do
          [[ -n "${g}" ]] && groups+=("${g}")
        done < <(jq -r '[.accounts[].group // empty] | unique[]' "${STATE_FILE}" 2>/dev/null)
      fi
      if [[ ${#groups[@]} -eq 0 ]]; then
        log_info "No groups defined."
      else
        printf "GROUPS:\n"
        local g
        for g in "${groups[@]}"; do
          local members
          members=$(jq -r --arg g "${g}" '[.accounts | to_entries[] | select(.value.group == $g) | .key] | join(", ")' "${STATE_FILE}" 2>/dev/null)
          printf "  %-20s %s\n" "${g}" "${members}"
        done
      fi
      ;;
    *)
      die "Usage: ${SCRIPT_NAME} group <set|unset|list> [args]"
      ;;
  esac
}

internal_uncooldown() {
  local alias="$1"
  set_account_state "${alias}" "cooldown_until" "0"
}

cmd_quota() {
  require_initialized
  load_config

  command -v curl >/dev/null 2>&1 || die "curl is required for quota checking"

  local json_output=0
  local args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --json) json_output=1 ;;
      *) args+=("${arg}") ;;
    esac
  done

  local aliases_to_check=()

  if (( ${#args[@]} > 0 )); then
    local alias="${args[0]}"
    validate_alias "${alias}" || die "Invalid alias '${alias}'."
    account_exists "${alias}" || die "Alias '${alias}' not found"
    aliases_to_check=("${alias}")
  else
    mapfile -t aliases_to_check < <(get_order)
  fi

  if (( ${#aliases_to_check[@]} == 0 )); then
    die "No accounts configured. Use '${SCRIPT_NAME} add' first."
  fi

  local alias email plan usage_json primary_pct primary_reset secondary_pct secondary_reset
  local credits_balance credits_unlimited plan_type_from_api

  if (( json_output == 1 )); then
    local json_result usage_error now_ts primary_reset_epoch secondary_reset_epoch
    local primary_reset_seconds secondary_reset_seconds item_json
    json_result="$(jq -n '[]')"

    for alias in "${aliases_to_check[@]}"; do
      email="$(get_account_email "${alias}")"
      plan="$(get_account_plan "${alias}")"
      email="${email:-unknown}"
      plan="${plan:-unknown}"
      usage_json="$(query_usage_api "${alias}")"

      if [[ "${usage_json}" == ERROR:* ]]; then
        usage_error="${usage_json#ERROR:}"
        item_json="$(jq -n \
          --arg alias "${alias}" \
          --arg email "${email}" \
          --arg plan "${plan}" \
          --arg error "${usage_error}" \
          '{
            alias: $alias,
            email: $email,
            plan: $plan,
            five_hour_usage_pct: null,
            weekly_usage_pct: null,
            five_hour_reset_seconds: null,
            weekly_reset_seconds: null,
            error: $error
          }')"
      else
        primary_pct="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.used_percent // 0' 2>/dev/null || true)"
        secondary_pct="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.secondary_window.used_percent // 0' 2>/dev/null || true)"
        [[ "${primary_pct}" =~ ^-?[0-9]+([.][0-9]+)?$ ]] || primary_pct="0"
        [[ "${secondary_pct}" =~ ^-?[0-9]+([.][0-9]+)?$ ]] || secondary_pct="0"

        primary_reset="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.reset_at // empty' 2>/dev/null || true)"
        secondary_reset="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.secondary_window.reset_at // empty' 2>/dev/null || true)"

        primary_reset_seconds="null"
        if [[ -n "${primary_reset}" ]]; then
          primary_reset_epoch="$(parse_reset_epoch "${primary_reset}")"
          now_ts="$(now_epoch)"
          if (( primary_reset_epoch > now_ts )); then
            primary_reset_seconds="$(( primary_reset_epoch - now_ts ))"
          else
            primary_reset_seconds="0"
          fi
        fi

        secondary_reset_seconds="null"
        if [[ -n "${secondary_reset}" ]]; then
          secondary_reset_epoch="$(parse_reset_epoch "${secondary_reset}")"
          now_ts="$(now_epoch)"
          if (( secondary_reset_epoch > now_ts )); then
            secondary_reset_seconds="$(( secondary_reset_epoch - now_ts ))"
          else
            secondary_reset_seconds="0"
          fi
        fi

        item_json="$(jq -n \
          --arg alias "${alias}" \
          --arg email "${email}" \
          --arg plan "${plan}" \
          --argjson five_hour_usage_pct "${primary_pct}" \
          --argjson weekly_usage_pct "${secondary_pct}" \
          --argjson five_hour_reset_seconds "${primary_reset_seconds}" \
          --argjson weekly_reset_seconds "${secondary_reset_seconds}" \
          '{
            alias: $alias,
            email: $email,
            plan: $plan,
            five_hour_usage_pct: $five_hour_usage_pct,
            weekly_usage_pct: $weekly_usage_pct,
            five_hour_reset_seconds: $five_hour_reset_seconds,
            weekly_reset_seconds: $weekly_reset_seconds,
            error: null
          }')"
      fi

      json_result="$(jq --argjson item "${item_json}" '. += [$item]' <<< "${json_result}")"
    done

    printf '%s\n' "${json_result}"
    return 0
  fi

  for alias in "${aliases_to_check[@]}"; do
    email="$(get_account_email "${alias}")"
    plan="$(get_account_plan "${alias}")"

    printf "\n%b━━━ %s ━━━%b\n" "${BLUE}" "${alias}" "${RESET}"
    printf "  Email:  %s\n" "${email:-unknown}"
    printf "  Plan:   %s\n" "${plan:-unknown}"

    usage_json="$(query_usage_api "${alias}")"

    if [[ "${usage_json}" == ERROR:* ]]; then
      local usage_error="${usage_json#ERROR:}"
      case "${usage_error}" in
        api_key)
          printf "  %b⚠ Usage API not available for API-key accounts%b\n" "${YELLOW}" "${RESET}"
          ;;
        no_token)
          printf "  %b⚠ No access token — try: %s refresh %s%b\n" "${YELLOW}" "${SCRIPT_NAME}" "${alias}" "${RESET}"
          ;;
        auth)
          printf "  %b⚠ Authentication failed (401/403) — try: %s refresh %s%b\n" "${YELLOW}" "${SCRIPT_NAME}" "${alias}" "${RESET}"
          ;;
        network)
          printf "  %b⚠ Network error — could not reach usage API (check internet connection)%b\n" "${YELLOW}" "${RESET}"
          ;;
        parse)
          printf "  %b⚠ Received invalid response from usage API (not valid JSON)%b\n" "${YELLOW}" "${RESET}"
          ;;
        http_*)
          local err_code="${usage_error#http_}"
          printf "  %b⚠ Usage API returned HTTP %s — try again later%b\n" "${YELLOW}" "${err_code}" "${RESET}"
          ;;
        *)
          printf "  %b⚠ Could not fetch usage data — try: %s refresh %s%b\n" "${YELLOW}" "${SCRIPT_NAME}" "${alias}" "${RESET}"
          ;;
      esac
      continue
    fi

    plan_type_from_api="$(printf "%s" "${usage_json}" | jq -r '.plan_type // empty' 2>/dev/null || true)"
    [[ -n "${plan_type_from_api}" ]] && printf "  Plan (API): %s\n" "${plan_type_from_api}"

    # Primary window (5-hour)
    primary_pct="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.used_percent // 0' 2>/dev/null || true)"
    primary_reset="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.primary_window.reset_at // empty' 2>/dev/null || true)"

    printf "  5-Hour Usage:  "
    format_usage_bar "${primary_pct}"
    if [[ -n "${primary_reset}" ]]; then
      local reset_epoch now_epoch_val remaining_secs
      reset_epoch="$(parse_reset_epoch "${primary_reset}")"
      now_epoch_val="$(now_epoch)"
      if (( reset_epoch > now_epoch_val )); then
        remaining_secs=$(( reset_epoch - now_epoch_val ))
        printf " (resets in %s)" "$(format_duration "${remaining_secs}")"
      fi
    fi
    printf "\n"

    # Secondary window (weekly)
    secondary_pct="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.secondary_window.used_percent // 0' 2>/dev/null || true)"
    secondary_reset="$(printf "%s" "${usage_json}" | jq -r '.rate_limit.secondary_window.reset_at // empty' 2>/dev/null || true)"

    printf "  Weekly Usage:  "
    format_usage_bar "${secondary_pct}"
    if [[ -n "${secondary_reset}" ]]; then
      local reset_epoch2 now_epoch_val2 remaining_secs2
      reset_epoch2="$(parse_reset_epoch "${secondary_reset}")"
      now_epoch_val2="$(now_epoch)"
      if (( reset_epoch2 > now_epoch_val2 )); then
        remaining_secs2=$(( reset_epoch2 - now_epoch_val2 ))
        printf " (resets in %s)" "$(format_duration "${remaining_secs2}")"
      fi
    fi
    printf "\n"

    # Credits
    credits_balance="$(printf "%s" "${usage_json}" | jq -r '.credits.balance // empty' 2>/dev/null || true)"
    credits_unlimited="$(printf "%s" "${usage_json}" | jq -r '.credits.unlimited // empty' 2>/dev/null || true)"
    if [[ "${credits_unlimited}" == "true" ]]; then
      printf "  Credits:  %b∞ Unlimited%b\n" "${GREEN}" "${RESET}"
    elif [[ -n "${credits_balance}" && "${credits_balance}" != "null" ]]; then
      printf "  Credits:  %s\n" "${credits_balance}"
    fi
  done
  printf "\n"
}

cmd_email() {
  require_initialized
  load_config

  local json_output=0
  local args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --json) json_output=1 ;;
      *) args+=("${arg}") ;;
    esac
  done

  local aliases_to_check=()

  if (( ${#args[@]} > 0 )); then
    local alias="${args[0]}"
    validate_alias "${alias}" || die "Invalid alias '${alias}'."
    account_exists "${alias}" || die "Alias '${alias}' not found"
    aliases_to_check=("${alias}")
  else
    mapfile -t aliases_to_check < <(get_order)
  fi

  if (( ${#aliases_to_check[@]} == 0 )); then
    die "No accounts configured. Use '${SCRIPT_NAME} add' first."
  fi

  if (( json_output == 1 )); then
    local json_result alias email plan tokens account_id access_token item_json
    json_result="$(jq -n '[]')"

    for alias in "${aliases_to_check[@]}"; do
      email="$(get_account_email "${alias}")"
      plan="$(get_account_plan "${alias}")"
      email="${email:-unknown}"
      plan="${plan:-unknown}"

      tokens="$(get_account_tokens "${alias}")"
      account_id="$(printf "%s" "${tokens}" | jq -r '.account_id // empty' 2>/dev/null || true)"
      if [[ -z "${account_id}" ]]; then
        access_token="$(printf "%s" "${tokens}" | jq -r '.access_token // empty' 2>/dev/null || true)"
        account_id="$(extract_account_id_from_token "${access_token}")"
      fi

      item_json="$(jq -n \
        --arg alias "${alias}" \
        --arg email "${email}" \
        --arg plan "${plan}" \
        --arg account_id "${account_id}" \
        '{
          alias: $alias,
          email: $email,
          plan: $plan,
          account_id: (if $account_id == "" then null else $account_id end)
        }')"

      json_result="$(jq --argjson item "${item_json}" '. += [$item]' <<< "${json_result}")"
    done

    printf '%s\n' "${json_result}"
    return 0
  fi

  printf "%-20s %-35s %-10s\n" "ALIAS" "EMAIL" "PLAN"
  printf "%-20s %-35s %-10s\n" "--------------------" "-----------------------------------" "----------"

  local alias email plan
  for alias in "${aliases_to_check[@]}"; do
    email="$(get_account_email "${alias}")"
    plan="$(get_account_plan "${alias}")"
    printf "%-20s %-35s %-10s\n" "${alias}" "${email:-unknown}" "${plan:-unknown}"
  done
}

cmd_refresh() {
  require_initialized
  load_config

  command -v curl >/dev/null 2>&1 || die "curl is required for token refresh"

  local aliases_to_refresh=()

  if (( $# > 0 )) && [[ "$1" != "--all" ]]; then
    local alias="$1"
    validate_alias "${alias}" || die "Invalid alias '${alias}'."
    account_exists "${alias}" || die "Alias '${alias}' not found"
    aliases_to_refresh=("${alias}")
  else
    # No args or --all: refresh all accounts
    mapfile -t aliases_to_refresh < <(get_order)
  fi

  if (( ${#aliases_to_refresh[@]} == 0 )); then
    die "No accounts configured. Use '${SCRIPT_NAME} add' first."
  fi

  local alias had_failure=0
  for alias in "${aliases_to_refresh[@]}"; do
    printf "Refreshing tokens for '%s'... " "${alias}"
    if refresh_account_token "${alias}"; then
      local email
      email="$(get_account_email "${alias}")"
      printf "%b✓%b (%s)\n" "${GREEN}" "${RESET}" "${email:-refreshed}"
    else
      printf "%b✗%b (failed)\n" "${RED}" "${RESET}"
      had_failure=1
    fi
  done
  return "${had_failure}"
}

cmd_doctor() {
  local errors=0 warnings=0

  printf "%s\n" "${SCRIPT_NAME} v${SCRIPT_VERSION} — System Diagnostics"
  printf "%s\n\n" "$(printf '%.0s─' {1..50})"

  # Check 1: Bash version >= 4
  printf "  %-35s " "Bash version (≥ 4 required)"
  if [[ ${BASH_VERSINFO[0]} -ge 4 ]]; then
    printf "\e[32m[✓]\e[0m %s\n" "v${BASH_VERSION}"
  else
    printf "\e[31m[✗]\e[0m %s\n" "v${BASH_VERSION} — Bash 4+ required"
    ((errors+=1))
  fi

  # Check 2: jq
  printf "  %-35s " "jq (JSON processor)"
  if command -v jq >/dev/null 2>&1; then
    printf "\e[32m[✓]\e[0m %s\n" "$(jq --version 2>&1)"
  else
    printf "\e[31m[✗]\e[0m %s\n" "not found — install with: apt install jq / brew install jq"
    ((errors+=1))
  fi

  # Check 3: curl
  printf "  %-35s " "curl (HTTP client)"
  if command -v curl >/dev/null 2>&1; then
    printf "\e[32m[✓]\e[0m %s\n" "$(curl --version 2>&1 | head -n 1 | cut -d' ' -f1-2)"
  else
    printf "\e[31m[✗]\e[0m %s\n" "not found — required for quota/refresh"
    ((errors+=1))
  fi

  # Check 4: flock
  printf "  %-35s " "flock (file locking)"
  if command -v flock >/dev/null 2>&1; then
    printf "\e[32m[✓]\e[0m %s\n" "available"
  else
    printf "\e[31m[✗]\e[0m %s\n" "not found — install with: apt install util-linux / brew install util-linux"
    ((errors+=1))
  fi

  # Check 5: Codex CLI
  printf "  %-35s " "Codex CLI"
  local codex_path
  codex_path=$(command -v codex 2>/dev/null || true)
  if [[ -n "${codex_path}" ]]; then
    printf "\e[32m[✓]\e[0m %s\n" "${codex_path}"
  else
    printf "\e[33m[!]\e[0m %s\n" "not found in PATH — required for run/auto commands"
    ((warnings+=1))
  fi

  # Check 6: Accounts directory
  printf "  %-35s " "Accounts directory"
  if [[ -d "${ACCOUNTS_DIR}" ]]; then
    local dir_perms
    dir_perms=$(stat -c "%a" "${ACCOUNTS_DIR}" 2>/dev/null || stat -f "%OLp" "${ACCOUNTS_DIR}" 2>/dev/null || echo "unknown")
    if [[ "${dir_perms}" == "700" ]]; then
      printf "\e[32m[✓]\e[0m %s\n" "${ACCOUNTS_DIR} (${dir_perms})"
    else
      printf "\e[33m[!]\e[0m %s\n" "${ACCOUNTS_DIR} (perms: ${dir_perms}, expected 700)"
      ((warnings+=1))
    fi
  else
    printf "\e[33m[!]\e[0m %s\n" "not initialized — run: ${SCRIPT_NAME} init"
    ((warnings+=1))
  fi

  # Check 7: Credentials directory permissions
  printf "  %-35s " "Credentials directory"
  if [[ -d "${CREDENTIALS_DIR}" ]]; then
    local cred_perms
    cred_perms=$(stat -c "%a" "${CREDENTIALS_DIR}" 2>/dev/null || stat -f "%OLp" "${CREDENTIALS_DIR}" 2>/dev/null || echo "unknown")
    if [[ "${cred_perms}" == "700" ]]; then
      printf "\e[32m[✓]\e[0m %s\n" "${CREDENTIALS_DIR} (${cred_perms})"
    else
      printf "\e[33m[!]\e[0m %s\n" "perms: ${cred_perms}, expected 700"
      ((warnings+=1))
    fi
  else
    printf "\e[33m[!]\e[0m %s\n" "not found"
    ((warnings+=1))
  fi

  # Check 8: Auth symlink
  printf "  %-35s " "Auth symlink"
  if [[ -L "${CODEX_AUTH}" ]]; then
    local target
    target=$(readlink "${CODEX_AUTH}" 2>/dev/null || echo "unknown")
    if [[ -f "${target}" ]]; then
      printf "\e[32m[✓]\e[0m %s\n" "→ ${target}"
    else
      printf "\e[31m[✗]\e[0m %s\n" "broken symlink → ${target}"
      ((errors+=1))
    fi
  elif [[ -f "${CODEX_AUTH}" ]]; then
    printf "\e[33m[!]\e[0m %s\n" "regular file (not managed by ${SCRIPT_NAME})"
    ((warnings+=1))
  else
    printf "\e[33m[!]\e[0m %s\n" "not found — add an account first"
    ((warnings+=1))
  fi

  # Check 9: Account count
  printf "  %-35s " "Accounts configured"
  local count=0
  if [[ -d "${CREDENTIALS_DIR}" ]]; then
    count=$(find "${CREDENTIALS_DIR}" -name '*.json' -type f 2>/dev/null | wc -l | tr -d ' ')
  fi
  if [[ "${count}" -gt 0 ]]; then
    printf "\e[32m[✓]\e[0m %s\n" "${count} account(s)"
  else
    printf "\e[33m[!]\e[0m %s\n" "no accounts — run: ${SCRIPT_NAME} add <alias>"
    ((warnings+=1))
  fi

  # Check 10: Token health (check active account)
  printf "  %-35s " "Active token health"
  if [[ -f "${ACTIVE_FILE}" ]]; then
    local active_alias
    active_alias=$(cat "${ACTIVE_FILE}" 2>/dev/null || echo "")
    if [[ -n "${active_alias}" && -f "${CREDENTIALS_DIR}/${active_alias}.json" ]]; then
      local access_token
      access_token=$(jq -r '.access_token // empty' "${CREDENTIALS_DIR}/${active_alias}.json" 2>/dev/null || echo "")
      if [[ -n "${access_token}" ]]; then
        # Check JWT expiry
        local payload
        payload=$(printf '%s' "${access_token}" | cut -d. -f2 2>/dev/null || echo "")
        if [[ -n "${payload}" ]]; then
          # Add padding
          local padded="${payload}"
          local mod=$(( ${#payload} % 4 ))
          if [[ ${mod} -eq 2 ]]; then
            padded="${payload}=="
          elif [[ ${mod} -eq 3 ]]; then
            padded="${payload}="
          fi
          local exp
          exp=$(printf '%s' "${padded}" | base64 -d 2>/dev/null | jq -r '.exp // empty' 2>/dev/null || echo "")
          if [[ -n "${exp}" ]]; then
            local now
            now=$(date +%s)
            if [[ "${exp}" -gt "${now}" ]]; then
              local remaining=$(( exp - now ))
              local hours=$(( remaining / 3600 ))
              local mins=$(( (remaining % 3600) / 60 ))
              printf "\e[32m[✓]\e[0m %s\n" "valid (expires in ${hours}h ${mins}m)"
            else
              printf "\e[31m[✗]\e[0m %s\n" "expired — run: ${SCRIPT_NAME} refresh ${active_alias}"
              ((errors++))
            fi
          else
            printf "\e[33m[!]\e[0m %s\n" "cannot parse expiry"
            ((warnings+=1))
          fi
        else
          printf "\e[33m[!]\e[0m %s\n" "cannot decode token"
          ((warnings+=1))
        fi
      else
        printf "\e[31m[✗]\e[0m %s\n" "no access_token in credential file"
        ((errors+=1))
      fi
    else
      printf "\e[33m[!]\e[0m %s\n" "no active account set"
      ((warnings+=1))
    fi
  else
    printf "\e[33m[!]\e[0m %s\n" "no active account"
    ((warnings+=1))
  fi

  printf "\n"
  if [[ ${errors} -eq 0 && ${warnings} -eq 0 ]]; then
    printf "\e[32m✓ All systems operational.\e[0m\n"
  elif [[ ${errors} -eq 0 ]]; then
    printf "\e[33m! %d warning(s), no errors.\e[0m\n" "${warnings}"
  else
    printf "\e[31m✗ %d error(s), %d warning(s).\e[0m\n" "${errors}" "${warnings}"
  fi

  return "${errors}"
}

cmd_upgrade() {
  if ! command -v npm >/dev/null 2>&1; then
    die "npm is required for upgrade. Install Node.js first, or upgrade manually."
  fi

  log_info "Checking for updates..."

  local current="${SCRIPT_VERSION}"
  local latest
  latest=$(npm view codex-rotate version 2>/dev/null || echo "")

  if [[ -z "${latest}" ]]; then
    die "Could not fetch latest version from npm registry."
  fi

  if [[ "${current}" == "${latest}" ]]; then
    log_info "Already on latest version (v${current})."
    return 0
  fi

  log_info "Update available: v${current} → v${latest}"

  # Fetch changelog summary if available
  local changelog_url="https://raw.githubusercontent.com/vaskoyudha/MultipleAccountCodex/main/CHANGELOG.md"
  local changelog
  changelog=$(curl -fsSL "${changelog_url}" 2>/dev/null || echo "")
  if [[ -n "${changelog}" ]]; then
    # Extract the section for the latest version
    local section
    section=$(printf '%s' "${changelog}" | sed -n "/^## \[${latest}\]/,/^## \[/p" | head -n -1)
    if [[ -n "${section}" ]]; then
      printf "\n%s\n\n" "${section}"
    fi
  fi

  log_info "Upgrading via npm..."
  if npm install -g codex-rotate@latest 2>&1; then
    log_info "Successfully upgraded to v${latest}."
  else
    log_error "Upgrade failed. Try manually: npm install -g codex-rotate@latest"
    return 1
  fi
}

cmd_tui() {
  local tui_cmd=""
  if command -v whiptail >/dev/null 2>&1; then
    tui_cmd="whiptail"
  elif command -v dialog >/dev/null 2>&1; then
    tui_cmd="dialog"
  else
    die "Neither whiptail nor dialog found. Install one: apt install whiptail / brew install dialog"
  fi

  local height=20 width=70 menu_height=12

  while true; do
    local choice
    choice=$("${tui_cmd}" --title "${SCRIPT_NAME} v${SCRIPT_VERSION}" \
      --menu "Select an action:" "${height}" "${width}" "${menu_height}" \
      "list" "List all accounts" \
      "status" "Account dashboard" \
      "quota" "Check usage/quota" \
      "email" "Show email & plan" \
      "switch" "Switch active account" \
      "add" "Add new account" \
      "refresh" "Refresh all tokens" \
      "doctor" "System diagnostics" \
      "cooldown" "Manage cooldowns" \
      "help" "Show help" \
      "exit" "Exit" \
      3>&1 1>&2 2>&3) || break

    case "${choice}" in
      list)
        "${tui_cmd}" --title "Account List" --msgbox "$(cmd_list 2>&1)" "${height}" "${width}"
        ;;
      status)
        "${tui_cmd}" --title "Status Dashboard" --msgbox "$(cmd_status 2>&1)" "${height}" 90
        ;;
      quota)
        "${tui_cmd}" --title "Quota Check" --infobox "Fetching quota data..." 5 40
        "${tui_cmd}" --title "Usage Quota" --msgbox "$(cmd_quota 2>&1)" "${height}" 90
        ;;
      email)
        "${tui_cmd}" --title "Account Emails" --msgbox "$(cmd_email 2>&1)" "${height}" "${width}"
        ;;
      switch)
        local items=()
        if [[ -f "${ORDER_FILE}" ]]; then
          while IFS= read -r alias_name; do
            [[ -z "${alias_name}" ]] && continue
            local active_mark=""
            if [[ -f "${ACTIVE_FILE}" ]]; then
              local current_active
              current_active="$(<"${ACTIVE_FILE}")"
              if [[ "${current_active}" == "${alias_name}" ]]; then
                active_mark=" (active)"
              fi
            fi
            items+=("${alias_name}" "${alias_name}${active_mark}")
          done < "${ORDER_FILE}"
        fi
        if [[ ${#items[@]} -eq 0 ]]; then
          "${tui_cmd}" --title "Switch" --msgbox "No accounts configured." 8 40
        else
          local selected
          selected=$("${tui_cmd}" --title "Switch Account" \
            --menu "Select account to activate:" "${height}" "${width}" "${menu_height}" \
            "${items[@]}" 3>&1 1>&2 2>&3) || continue
          local switch_output
          switch_output="$(cmd_switch "${selected}" 2>&1)"
          "${tui_cmd}" --title "Switched" --msgbox "${switch_output}" 8 60
        fi
        ;;
      add)
        local new_alias
        new_alias=$("${tui_cmd}" --title "Add Account" \
          --inputbox "Enter alias name for new account:" 10 50 3>&1 1>&2 2>&3) || continue
        if [[ -n "${new_alias}" ]]; then
          "${tui_cmd}" --title "Adding Account" --infobox "Opening browser login for '${new_alias}'..." 5 50
          local add_output
          add_output="$(cmd_add "${new_alias}" 2>&1)"
          "${tui_cmd}" --title "Add Account" --msgbox "${add_output}" "${height}" "${width}"
        fi
        ;;
      refresh)
        "${tui_cmd}" --title "Refresh" --infobox "Refreshing all tokens..." 5 40
        local refresh_output
        refresh_output=$(cmd_refresh 2>&1)
        "${tui_cmd}" --title "Refresh Results" --msgbox "${refresh_output}" "${height}" "${width}"
        ;;
      doctor)
        local doc_output
        doc_output=$(cmd_doctor 2>&1)
        "${tui_cmd}" --title "System Diagnostics" --msgbox "${doc_output}" "${height}" 90
        ;;
      cooldown)
        local cd_items=()
        if [[ -f "${ORDER_FILE}" ]]; then
          while IFS= read -r alias_name; do
            [[ -z "${alias_name}" ]] && continue
            cd_items+=("${alias_name}" "Manage cooldown")
          done < "${ORDER_FILE}"
        fi
        if [[ ${#cd_items[@]} -eq 0 ]]; then
          "${tui_cmd}" --title "Cooldown" --msgbox "No accounts." 8 40
        else
          local cd_selected
          cd_selected=$("${tui_cmd}" --title "Cooldown Management" \
            --menu "Select account:" "${height}" "${width}" "${menu_height}" \
            "${cd_items[@]}" 3>&1 1>&2 2>&3) || continue
          local cd_action
          cd_action=$("${tui_cmd}" --title "Cooldown: ${cd_selected}" \
            --menu "Action:" 12 50 3 \
            "cooldown" "Set cooldown (1 hour)" \
            "uncooldown" "Clear cooldown" \
            "back" "Go back" \
            3>&1 1>&2 2>&3) || continue
          case "${cd_action}" in
            cooldown)
              cmd_cooldown "${cd_selected}" >/dev/null 2>&1 || true
              "${tui_cmd}" --msgbox "Cooldown set for ${cd_selected}" 8 40
              ;;
            uncooldown)
              cmd_uncooldown "${cd_selected}" >/dev/null 2>&1 || true
              "${tui_cmd}" --msgbox "Cooldown cleared for ${cd_selected}" 8 40
              ;;
          esac
        fi
        ;;
      help)
        "${tui_cmd}" --title "Help" --msgbox "$(cmd_help 2>&1)" "${height}" 90
        ;;
      exit|"")
        break
        ;;
    esac
  done
}

cmd_help() {
  cat <<EOF
${SCRIPT_NAME} v${SCRIPT_VERSION}

Codex account rotation manager.

Usage:
  ${SCRIPT_NAME} <command> [args]

Commands:
  init
      Initialize ~/.codex-accounts structure and default config.

  add <alias> [--force] [--group=<name>]
      Interactive login flow to add account credentials under alias.

  import <alias> <path>
      Import existing auth.json file as an account alias.

  remove <alias>
      Remove an account alias and associated state.

  list
      Show account table (alias, email, status, uses, plan, last used, cooldown).

  switch <alias> [--force]
      Switch active account by atomically updating auth.json symlink.

  status
      Show dashboard view of accounts and rotation configuration.

  run [codex args...]
      Transparent codex wrapper with automatic rate-limit rotation/retry.

  auto [codex args...]
      Same as run, but pre-rotates if last_used exceeds ROTATION_INTERVAL.

  Options for run/auto:
    --group=<name>   Only rotate among accounts in specified group.

  cooldown <alias> [--hours N | --days N | --weeks N]
      Manually put account on cooldown (default: 1 hour).

  uncooldown <alias>
      Manually clear account cooldown.

  quota [alias]
      Show real-time usage/quota from OpenAI API for one or all accounts.

  email [alias]
      Display email and plan type extracted from account tokens.

  refresh [alias|--all]
      Refresh access tokens using stored refresh_token.
      Without args or with --all, refreshes all accounts.

  doctor
      Run system diagnostics (check dependencies, permissions, tokens).

  upgrade
      Check for updates and upgrade to the latest version via npm.

  tui
      Interactive terminal menu (requires whiptail or dialog).

  group <set|unset|list> [args]
      Manage account groups.
      set <alias> <group>   — assign account to a group
      unset <alias>         — remove group assignment
      list                  — show all groups and members

  help
      Show this help.

  Notifications (configure in ~/.codex-accounts/config.sh):
    NOTIFY_DESKTOP=1              Enable desktop notifications
    NOTIFY_WEBHOOK_URL="..."      Webhook URL (Slack, Discord, etc.)
    NOTIFY_WEBHOOK_TYPE="slack"   Type: slack, discord, telegram, generic

Notes:
  - Credentials are stored at: ${CREDENTIALS_DIR}/<alias>.json
  - Active auth symlink: ${CODEX_AUTH}
  - State file: ${STATE_FILE}
  - Config file: ${CONFIG_FILE}
  - Override codex binary via CODEX_BIN in config.sh
EOF
}

###############################################################################
# Internal command router (for lock-safe mutations)
###############################################################################

dispatch_internal() {
  local subcmd="$1"
  shift
  case "${subcmd}" in
    __internal_add_state) internal_add_state "$@" ;;
    __internal_remove) internal_remove "$@" ;;
    __internal_switch) internal_switch "$@" ;;
    __internal_mark_rate_limit) internal_mark_rate_limit "$@" ;;
    __internal_increment_use) internal_increment_use "$@" ;;
    __internal_ensure_active_ready) internal_ensure_active_ready "$@" ;;
    __internal_auto_preflight) internal_auto_preflight "$@" ;;
    __internal_cooldown) internal_cooldown "$@" ;;
    __internal_uncooldown) internal_uncooldown "$@" ;;
    __internal_group_set) internal_group_set "$@" ;;
    __internal_group_unset) internal_group_unset "$@" ;;
    *) die "Unknown internal subcommand: ${subcmd}" ;;
  esac
}

###############################################################################
# Main command router
###############################################################################

main() {
  check_prerequisites

  local cmd="${1:-help}"
  shift || true

  # Internal subcommands are not public; used through with_lock.
  if [[ "${cmd}" == __internal_* ]]; then
    require_initialized
    load_config
    dispatch_internal "${cmd}" "$@"
    return 0
  fi

  case "${cmd}" in
    init) cmd_init "$@" ;;
    add) cmd_add "$@" ;;
    import) cmd_import "$@" ;;
    remove) cmd_remove "$@" ;;
    list) cmd_list "$@" ;;
    switch) cmd_switch "$@" ;;
    status) cmd_status "$@" ;;
    run) cmd_run "$@" ;;
    auto) cmd_auto "$@" ;;
    cooldown) cmd_cooldown "$@" ;;
    uncooldown) cmd_uncooldown "$@" ;;
    quota) cmd_quota "$@" ;;
    email) cmd_email "$@" ;;
    refresh) cmd_refresh "$@" ;;
    doctor) cmd_doctor ;;
    upgrade) cmd_upgrade ;;
    tui) cmd_tui ;;
    group) cmd_group "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      log_error "Unknown command: ${cmd}"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
